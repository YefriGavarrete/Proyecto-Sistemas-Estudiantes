@model Proyecto_Evaluacion_Estudiantes.Models.PrediccionRiesgoViewModel
@{
    ViewData["Title"] = "Predicción — " + Model.EstudianteInfo.NombreCompleto;
    var e    = Model.EstudianteInfo;
    int pct  = (int)Math.Round(Model.Probabilidad * 100);

    // Datos Chart.js: null → "null" literal en JS para omitir el punto
    string JsVal(float? v) => v.HasValue ? v.Value.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) : "null";
}

<div class="page-wrapper">
    <div class="content">

        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
                <li class="breadcrumb-item"><a asp-action="Buscar">Predicción IA</a></li>
                <li class="breadcrumb-item active">@e.NombreCompleto</li>
            </ol>
        </nav>

        <div class="row g-4">

            <!-- ── Columna izquierda ─────────────────────────────────────── -->
            <div class="col-lg-4">

                <!-- Tarjeta del estudiante -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white">
                        <i class="fa fa-user-graduate me-2"></i> Información del Estudiante
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0" style="font-size:.93rem;">
                            <dt class="col-5 text-muted">Nombre</dt>
                            <dd class="col-7 fw-bold">@e.NombreCompleto</dd>

                            <dt class="col-5 text-muted">Código</dt>
                            <dd class="col-7">
                                <span class="badge bg-secondary">@e.Codigo</span>
                            </dd>

                            <dt class="col-5 text-muted">Correo</dt>
                            <dd class="col-7 text-break">@e.Correo</dd>

                            <dt class="col-5 text-muted">Curso</dt>
                            <dd class="col-7">@e.Curso?.Grado?.Nombre @e.Curso?.Seccion</dd>

                            <dt class="col-5 text-muted">Promedio</dt>
                            <dd class="col-7">
                                @if (e.Promedio.HasValue)
                                {
                                    <strong class="@(e.Promedio >= 60 ? "text-success" : "text-danger")">
                                        @e.Promedio.Value.ToString("0.00")
                                    </strong>
                                }
                                else
                                {
                                    <span class="text-muted">Sin notas</span>
                                }
                            </dd>

                            <dt class="col-5 text-muted">Estado</dt>
                            <dd class="col-7">
                                @{
                                    var sc = e.Estado == "Aprobado" ? "bg-success"
                                           : e.Estado == "Reprobado" ? "bg-danger"
                                           : "bg-secondary";
                                }
                                <span class="badge @sc">@(e.Estado ?? "Sin Notas")</span>
                            </dd>
                        </dl>
                    </div>
                </div>

                <!-- Historial de notas -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header">
                        <i class="fa fa-table me-2 text-primary"></i> Historial de Notas
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Parcial</th>
                                    <th class="text-center">Nota</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int p = 1; p <= 4; p++)
                                {
                                    var nota  = e.NotaParcial(p);
                                    var fecha = e.FechaParcial(p);
                                    <tr>
                                        <td><strong>Parcial @p</strong></td>
                                        <td class="text-center">
                                            @if (nota.HasValue)
                                            {
                                                <span class="fw-bold @(nota.Value >= 60 ? "text-success" : "text-danger")">
                                                    @nota.Value.ToString("0.00")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-muted">Pendiente</span>
                                            }
                                        </td>
                                        <td class="text-muted" style="font-size:.82rem;">
                                            @(fecha.HasValue ? fecha.Value.ToString("dd/MM/yyyy") : "—")
                                        </td>
                                    </tr>
                                }
                                <tr class="table-light fw-bold">
                                    <td>Promedio</td>
                                    <td class="text-center">
                                        @if (Model.PromedioActual > 0)
                                        {
                                            <span class="@(Model.PromedioActual >= 60 ? "text-success" : "text-danger")">
                                                @Model.PromedioActual.ToString("0.00")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <a asp-action="Buscar" class="btn btn-outline-secondary w-100">
                    <i class="fa fa-arrow-left me-1"></i> Volver a búsqueda
                </a>
            </div>

            <!-- ── Columna derecha ──────────────────────────────────────── -->
            <div class="col-lg-8">

                <!-- Tarjeta de predicción ML -->
                <div class="card shadow mb-4 border-0"
                     style="background:linear-gradient(135deg,#0d1b2a 0%,#1a3a5c 100%);color:#fff;">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="fa fa-brain me-2" style="font-size:28px;color:#48cae4;"></i>
                            <h4 class="mb-0">Análisis de Riesgo con IA</h4>
                        </div>

                        <div class="row align-items-center">
                            <div class="col-auto text-center me-3">
                                <div style="font-size:72px;font-weight:900;line-height:1;
                                            color:@(Model.NivelRiesgo == "Alto" ? "#ff6b6b"
                                                  : Model.NivelRiesgo == "Medio" ? "#ffd166"
                                                  : "#06d6a0");">
                                    @pct%
                                </div>
                                <div class="mt-1">
                                    <span class="badge @Model.BadgeRiesgo fs-6 px-3">
                                        RIESGO @Model.NivelRiesgo.ToUpper()
                                    </span>
                                </div>
                            </div>
                            <div class="col">
                                <!-- Barra de progreso -->
                                <div class="mb-2" style="font-size:.85rem;color:rgba(255,255,255,.7);">
                                    Probabilidad de no aprobar el período
                                </div>
                                <div class="progress mb-3" style="height:18px;background:rgba(255,255,255,.15);">
                                    <div class="progress-bar @Model.BadgeRiesgo"
                                         role="progressbar"
                                         style="width:@pct%;"
                                         aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                        @pct%
                                    </div>
                                </div>
                                <!-- Escala -->
                                <div class="d-flex justify-content-between" style="font-size:.78rem;color:rgba(255,255,255,.6);">
                                    <span><i class="fa fa-circle text-success me-1"></i>Bajo (0–39%)</span>
                                    <span><i class="fa fa-circle text-warning me-1"></i>Medio (40–65%)</span>
                                    <span><i class="fa fa-circle text-danger me-1"></i>Alto (66–100%)</span>
                                </div>
                                <!-- Mensaje -->
                                <div class="alert mt-3 mb-0"
                                     style="background:rgba(255,255,255,.1);border:none;color:#fff;font-size:.9rem;">
                                    <i class="fa fa-info-circle me-2"></i>@Model.MensajeRiesgo
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Gráfico de rendimiento -->
                <div class="card shadow-sm">
                    <div class="card-header">
                        <i class="fa fa-chart-line me-2 text-primary"></i> Rendimiento por Parcial
                    </div>
                    <div class="card-body">
                        <canvas id="graficoRendimiento" height="120"></canvas>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script>
(function () {
    var ctx = document.getElementById('graficoRendimiento').getContext('2d');
    var datos = [@JsVal(Model.DatosGrafico[0]), @JsVal(Model.DatosGrafico[1]), @JsVal(Model.DatosGrafico[2]), @JsVal(Model.DatosGrafico[3])];

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Parcial 1', 'Parcial 2', 'Parcial 3', 'Parcial 4'],
            datasets: [
                {
                    label: 'Nota del estudiante',
                    data: datos,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13,110,253,.12)',
                    borderWidth: 2.5,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    spanGaps: false,
                    fill: true,
                    tension: 0.3
                },
                {
                    label: 'Nota mínima aprobatoria (60)',
                    data: [60, 60, 60, 60],
                    borderColor: '#dc3545',
                    borderDash: [6, 4],
                    borderWidth: 1.5,
                    pointRadius: 0,
                    fill: false
                }
            ]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    min: 0,
                    max: 100,
                    title: { display: true, text: 'Nota (0–100)' }
                }
            },
            plugins: {
                tooltip: { mode: 'index', intersect: false },
                legend: { position: 'bottom' }
            }
        }
    });
})();
</script>
}
