@model Proyecto_Evaluacion_Estudiantes.Models.EstudianteIndexViewModel
@{
    ViewData["Title"] = "Predicción de Riesgo Académico";
    string q = ViewData["q"]?.ToString() ?? "";
    bool busquedaRealizada = !string.IsNullOrWhiteSpace(q);
}

<div class="page-wrapper">
    <div class="content">

        <!-- Encabezado -->
        <div class="page-header mb-4">
            <div class="row align-items-center">
                <div class="col">
                    <h3 class="page-title">
                        <i class="fa fa-brain me-2" style="color:#0d6efd;"></i>
                        Predicción de Riesgo Académico
                    </h3>
                    <p class="text-muted mb-0">
                        Busca un estudiante para analizar su riesgo académico con Inteligencia Artificial.
                    </p>
                </div>
            </div>
        </div>

        <!-- Formulario de búsqueda -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form method="get" asp-action="Buscar" asp-controller="Prediccion">
                    <div class="input-group">
                        <span class="input-group-text bg-primary text-white">
                            <i class="fa fa-search"></i>
                        </span>
                        <input type="text"
                               name="q"
                               value="@q"
                               class="form-control form-control-lg"
                               placeholder="Nombre, apellido, código o número de identidad del estudiante..."
                               autocomplete="off"
                               autofocus />
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fa fa-search me-1"></i> Buscar
                        </button>
                        @if (busquedaRealizada)
                        {
                            <a asp-action="Buscar" class="btn btn-outline-secondary">
                                <i class="fa fa-times me-1"></i> Limpiar
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>

        @if (!busquedaRealizada)
        {
            <!-- Estado vacío inicial -->
            <div class="text-center py-5" style="opacity:.7;">
                <i class="fa fa-search-plus" style="font-size:64px;color:#0d6efd;"></i>
                <h5 class="mt-3 text-muted">Ingresa el nombre, código o identidad de un estudiante para comenzar</h5>
                <p class="text-muted">El sistema analizará sus notas y estimará la probabilidad de riesgo académico.</p>
            </div>
        }
        else if (Model.Estudiantes.Count == 0)
        {
            <!-- Sin resultados -->
            <div class="alert alert-warning d-flex align-items-center">
                <i class="fa fa-exclamation-triangle me-2"></i>
                No se encontraron estudiantes con el criterio <strong class="ms-1">"@q"</strong>.
                Verifica el nombre, código o identidad e intenta de nuevo.
            </div>
        }
        else
        {
            <!-- Tabla de resultados -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fa fa-list me-1 text-primary"></i>
                        Resultados para "@q"
                    </h5>
                    <span class="badge bg-primary">@Model.Estudiantes.Count estudiante(s)</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Código</th>
                                    <th>Nombre Completo</th>
                                    <th>Curso</th>
                                    <th class="text-center">Promedio</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in Model.Estudiantes)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-secondary">@e.Codigo</span>
                                        </td>
                                        <td>
                                            <strong>@e.NombreCompleto</strong>
                                        </td>
                                        <td>
                                            @e.Curso?.Grado?.Nombre @e.Curso?.Seccion
                                        </td>
                                        <td class="text-center">
                                            @if (e.Promedio.HasValue)
                                            {
                                                <span class="fw-bold @(e.Promedio >= 60 ? "text-success" : "text-danger")">
                                                    @e.Promedio.Value.ToString("0.00")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var badgeCls = e.Estado == "Aprobado" ? "bg-success"
                                                             : e.Estado == "Reprobado" ? "bg-danger"
                                                             : "bg-secondary";
                                            }
                                            <span class="badge @badgeCls">@(e.Estado ?? "Sin Notas")</span>
                                        </td>
                                        <td class="text-center">
                                            <a asp-action="Resultado"
                                               asp-route-estudianteId="@e.Id"
                                               class="btn btn-sm btn-primary">
                                                <i class="fa fa-brain me-1"></i> Ver predicción
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

    </div>
</div>
