@model Proyecto_Evaluacion_Estudiantes.Models.PerfilViewModel
@{
    ViewData["Title"]      = "Mi Perfil — EduPath AI";
    ViewData["ActiveMenu"] = "Configuracion";
    var rolSlug = Model.Rol == "Administrador" ? "admin" : "docente";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="user" class="me-2 ico-azul"></i>
                    Mi Perfil
                </h4>
                <h6>EduPath AI — Información de tu cuenta</h6>
            </div>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i data-feather="check-circle" class="me-2 ico-azul"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">

            <!-- Columna izquierda: avatar + subida de foto -->
            <div class="col-xl-4 col-lg-4 col-md-5 mb-4">
                <div class="card h-100 perfil-card-rol-@rolSlug">
                    <div class="card-body d-flex flex-column align-items-center text-center p-4">

                        <div class="perfil-avatar-wrapper">
                            @if (Model.TieneFoto)
                            {
                                <img id="avatarImg"
                                     src="@Model.FotoUrl"
                                     alt="Foto de perfil"
                                     class="perfil-avatar-img perfil-avatar-borde-@rolSlug"
                                     onerror="this.style.display='none';document.getElementById('avatarIcono').style.display='flex';" />



                                <div id="avatarIcono"
                                     class="perfil-avatar-circle perfil-avatar-borde-@rolSlug d-none">
                                    @Model.Iniciales
                                </div>
                            }
                            else
                            {
                                <div id="avatarImg"
                                     class="perfil-avatar-circle perfil-avatar-borde-@rolSlug">
                                    @Model.Iniciales
                                </div>
                                <img id="avatarPreview" src="#" alt=""
                                     class="perfil-avatar-img perfil-avatar-borde-@rolSlug d-none" />
                            }
                            <span class="perfil-avatar-online"></span>
                        </div>

                        <h5 class="perfil-nombre">
                            @(string.IsNullOrEmpty(Model.Titulo)
                                ? Model.NombreCompleto
                                : $"{Model.Titulo} {Model.NombreCompleto}")
                        </h5>

                        <span class="perfil-rol-badge perfil-badge-bg-@rolSlug">
                            @Model.Rol
                        </span>

                        <p class="perfil-codigo">
                            <i data-feather="hash" class="ico-13"></i>
                            @Model.Codigo
                        </p>

                        <hr class="w-100" />

                        <form asp-action="Perfil" asp-controller="Home"
                              method="post" enctype="multipart/form-data"
                              id="formFoto" class="w-100">
                            @Html.AntiForgeryToken()

                            <input type="file" id="inputFoto" name="FotoFile"
                                   accept="image/jpeg,image/png,image/webp"
                                   class="d-none" />

                            <small class="text-muted d-block mb-3 perfil-hint">
                                JPG, PNG o WEBP · Máximo 2 MB
                            </small>

                            <button type="button" id="btnElegir"
                                    onclick="document.getElementById('inputFoto').click()"
                                    class="perfil-btn-elegir mb-2">
                                <i data-feather="image" class="ico-15"></i>
                                Elegir foto
                            </button>

                            <small id="nombreArchivo" class="text-muted d-block mb-3 perfil-hint"></small>

                            <button type="submit" id="btnGuardar"
                                    class="perfil-btn-guardar perfil-badge-bg-@rolSlug"
                                    style="display:none">
                                <i data-feather="save" class="ico-15 ico-blanco"></i>
                                Guardar foto
                            </button>
                        </form>

                    </div>
                </div>
            </div>




            <!-- Columna derecha: datos de cuenta -->
            <div class="col-xl-8 col-lg-8 col-md-7 mb-4">
                <div class="card h-100">
                    <div class="card-body p-4">

                        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                            <div class="admin-stat-icon perfil-info-header me-3">
                                <i data-feather="info" class="ico-20 ico-blanco"></i>
                            </div>
                            <div>
                                <h5 class="perfil-info-title">Información de la Cuenta</h5>
                                <small class="text-muted">Datos registrados en el sistema. Solo lectura.</small>
                            </div>
                        </div>

                        <h6 class="perfil-seccion-titulo">
                            <i data-feather="user" class="ico-13"></i>
                            Datos Personales
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Nombre Completo</label>
                                <div class="perfil-campo">
                                    <i data-feather="user" class="ico-14 ico-celeste"></i>
                                    @Model.NombreCompleto
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Titulo))
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Título Académico</label>
                                    <div class="perfil-campo">
                                        <i data-feather="award" class="ico-14 ico-celeste"></i>
                                        @Model.Titulo
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.Correo))
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Correo Electrónico</label>
                                    <div class="perfil-campo">
                                        <i data-feather="mail" class="ico-14 ico-celeste"></i>
                                        @Model.Correo
                                    </div>
                                </div>
                            }
                        </div>

                        <hr />

                        <h6 class="perfil-seccion-titulo mt-3">
                            <i data-feather="shield" class="ico-13"></i>
                            Cuenta del Sistema
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Nombre de Usuario</label>
                                <div class="perfil-campo">
                                    <i data-feather="at-sign" class="ico-14 ico-celeste"></i>
                                    @Model.Usuario
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Rol en el Sistema</label>
                                <div class="perfil-campo">
                                    <span class="perfil-rol-badge perfil-badge-bg-@rolSlug perfil-badge-sm">
                                        @Model.Rol
                                    </span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Código</label>
                                <div class="perfil-campo">
                                    <i data-feather="hash" class="ico-14 ico-celeste"></i>
                                    @Model.Codigo
                                </div>
                            </div>

                            @if (Model.FechaCreacion.HasValue)
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Cuenta Creada</label>
                                    <div class="perfil-campo">
                                        <i data-feather="calendar" class="ico-14 ico-celeste"></i>
                                        @Model.FechaCreacion.Value.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            }

                            @if (Model.UltimoAcceso.HasValue)
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Último Acceso</label>
                                    <div class="perfil-campo">
                                        <i data-feather="clock" class="ico-14 ico-verde"></i>
                                        @Model.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="perfil-nota-seguridad">
                            <i data-feather="lock" class="flex-shrink-0 ico-15 ico-celeste"></i>
                            <small>
                                Para cambiar tu contraseña o datos personales, contacta al
                                administrador del sistema.
                            </small>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.feather) feather.replace();

    const inputFoto     = document.getElementById('inputFoto');
    const btnGuardar    = document.getElementById('btnGuardar');
    const nombreArchivo = document.getElementById('nombreArchivo');
    const avatarImg     = document.getElementById('avatarImg');     
    const avatarIcono   = document.getElementById('avatarIcono');   // fallback de iniciales (solo cuando TieneFoto=true)
    const avatarPreview = document.getElementById('avatarPreview'); // img de previsualización (solo cuando TieneFoto=false)

    inputFoto?.addEventListener('change', function () {


        const file = this.files[0];
        if (!file) return;

        nombreArchivo.textContent = file.name;

        const reader = new FileReader();
        reader.onload = function (e) {
            if (avatarPreview) {
                // Caso: sin foto guardada — ocultar círculo de iniciales, mostrar preview
                avatarImg.style.display = 'none';
                avatarPreview.src = e.target.result;
                avatarPreview.classList.remove('d-none'); // d-none usa !important; style inline no lo sobrescribe
            } else if (avatarImg && avatarImg.tagName === 'IMG') {
                // Caso: foto ya guardada — reemplazar la imagen directamente
                avatarImg.src = e.target.result;
                if (avatarIcono) avatarIcono.style.display = 'none';
            }
        };
        reader.readAsDataURL(file);

        if (btnGuardar) btnGuardar.style.display = 'flex';
        if (window.feather) feather.replace();
    });
});
</script>
}
