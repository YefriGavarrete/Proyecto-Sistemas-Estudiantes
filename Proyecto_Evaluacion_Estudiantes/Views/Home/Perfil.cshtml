@model Proyecto_Evaluacion_Estudiantes.Models.PerfilViewModel
@{
    ViewData["Title"]      = "Mi Perfil — EduPath AI";
    ViewData["ActiveMenu"] = "Configuracion";
    var rolSlug = Model.Rol == "Administrador" ? "admin" : "docente";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="user" class="me-2 ico-azul"></i>
                    Mi Perfil
                </h4>
                <h6>EduPath AI — Información de tu cuenta</h6>
            </div>
        </div>

        <div class="row">

            <!-- Columna izquierda: avatar con iniciales -->
            <div class="col-xl-4 col-lg-4 col-md-5 mb-4">
                <div class="card h-100 perfil-card-rol-@rolSlug">
                    <div class="card-body d-flex flex-column align-items-center text-center p-4">

                        <div class="perfil-avatar-wrapper mb-3">
                            <div class="perfil-avatar-circle perfil-avatar-borde-@rolSlug">
                                @Model.Iniciales
                            </div>
                            <span class="perfil-avatar-online"></span>
                        </div>

                        <h5 class="perfil-nombre">
                            @(string.IsNullOrEmpty(Model.Titulo)
                                ? Model.NombreCompleto
                                : $"{Model.Titulo} {Model.NombreCompleto}")
                        </h5>

                        <span class="perfil-rol-badge perfil-badge-bg-@rolSlug">
                            @Model.Rol
                        </span>

                        <p class="perfil-codigo mt-2">
                            <i data-feather="hash" class="ico-13"></i>
                            @Model.Codigo
                        </p>

                    </div>
                </div>
            </div>

            <!-- Columna derecha: datos de cuenta -->
            <div class="col-xl-8 col-lg-8 col-md-7 mb-4">
                <div class="card h-100">
                    <div class="card-body p-4">

                        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                            <div class="admin-stat-icon perfil-info-header me-3">
                                <i data-feather="info" class="ico-20 ico-blanco"></i>
                            </div>
                            <div>
                                <h5 class="perfil-info-title">Información de la Cuenta</h5>
                                <small class="text-muted">Datos registrados en el sistema. Solo lectura.</small>
                            </div>
                        </div>

                        <h6 class="perfil-seccion-titulo">
                            <i data-feather="user" class="ico-13"></i>
                            Datos Personales
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Nombre Completo</label>
                                <div class="perfil-campo">
                                    <i data-feather="user" class="ico-14 ico-celeste"></i>
                                    @Model.NombreCompleto
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Titulo))
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Título Académico</label>
                                    <div class="perfil-campo">
                                        <i data-feather="award" class="ico-14 ico-celeste"></i>
                                        @Model.Titulo
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.Correo))
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Correo Electrónico</label>
                                    <div class="perfil-campo">
                                        <i data-feather="mail" class="ico-14 ico-celeste"></i>
                                        @Model.Correo
                                    </div>
                                </div>
                            }
                        </div>

                        <hr />

                        <h6 class="perfil-seccion-titulo mt-3">
                            <i data-feather="shield" class="ico-13"></i>
                            Cuenta del Sistema
                        </h6>

                        <div class="row g-3 mb-4">
                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Nombre de Usuario</label>
                                <div class="perfil-campo">
                                    <i data-feather="at-sign" class="ico-14 ico-celeste"></i>
                                    @Model.Usuario
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Rol en el Sistema</label>
                                <div class="perfil-campo">
                                    <span class="perfil-rol-badge perfil-badge-bg-@rolSlug perfil-badge-sm">
                                        @Model.Rol
                                    </span>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <label class="form-label perfil-label-small">Código</label>
                                <div class="perfil-campo">
                                    <i data-feather="hash" class="ico-14 ico-celeste"></i>
                                    @Model.Codigo
                                </div>
                            </div>

                            @if (Model.FechaCreacion.HasValue)
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Cuenta Creada</label>
                                    <div class="perfil-campo">
                                        <i data-feather="calendar" class="ico-14 ico-celeste"></i>
                                        @Model.FechaCreacion.Value.ToString("dd/MM/yyyy")
                                    </div>
                                </div>
                            }

                            @if (Model.UltimoAcceso.HasValue)
                            {
                                <div class="col-sm-6">
                                    <label class="form-label perfil-label-small">Último Acceso</label>
                                    <div class="perfil-campo">
                                        <i data-feather="clock" class="ico-14 ico-verde"></i>
                                        @Model.UltimoAcceso.Value.ToString("dd/MM/yyyy HH:mm")
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="perfil-nota-seguridad">
                            <i data-feather="lock" class="flex-shrink-0 ico-15 ico-celeste"></i>
                            <small>
                                Para cambiar tu contraseña o datos personales, contacta al
                                administrador del sistema.
                            </small>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.feather) feather.replace();
});
</script>
}
