@{
    ViewData["Title"] = "Dashboard — EduPath AI";
    ViewData["ActiveMenu"] = "Dashboard";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>Dashboard Académico</h4>
                <h6>EduPath AI — Sistema Inteligente de Evaluación y Predicción Estudiantil</h6>
            </div>
        </div>

        <!-- ====== Fila 1: KPIs de métricas acumuladas ====== -->
        <div class="row">
            <div class="col-lg-3 col-sm-6 col-12">
                <div class="dash-widget">
                    <div class="dash-widgetimg">
                        <span><img src="~/img/icons/dash1.svg" alt="img"></span>
                    </div>
                    <div class="dash-widgetcontent">
                        <h5><span class="counters" data-count="@(ViewData["TotalEstudiantes"] ?? 0)">
                            @(ViewData["TotalEstudiantes"] ?? 0)
                        </span></h5>
                        <h6>Total de Estudiantes</h6>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12">
                <div class="dash-widget dash1">
                    <div class="dash-widgetimg">
                        <span><img src="~/img/icons/dash2.svg" alt="img"></span>
                    </div>
                    <div class="dash-widgetcontent">
                        <h5><span class="counters" data-count="@(ViewData["PromedioGeneral"] ?? "0.00")">
                            @(ViewData["PromedioGeneral"] ?? "0.00")
                        </span></h5>
                        <h6>Promedio General del Grupo</h6>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12">
                <div class="dash-widget dash2">
                    <div class="dash-widgetimg">
                        <span><img src="~/img/icons/dash3.svg" alt="img"></span>
                    </div>
                    <div class="dash-widgetcontent">
                        <h5><span class="counters" data-count="@(ViewData["PorcentajeAprobados"] ?? "0")">
                            @(ViewData["PorcentajeAprobados"] ?? "0")%
                        </span></h5>
                        <h6>Porcentaje de Aprobación</h6>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12">
                <div class="dash-widget dash3">
                    <div class="dash-widgetimg">
                        <span><img src="~/img/icons/dash4.svg" alt="img"></span>
                    </div>
                    <div class="dash-widgetcontent">
                        <h5><span class="counters" data-count="@(ViewData["EstudiantesEnRiesgo"] ?? 0)">
                            @(ViewData["EstudiantesEnRiesgo"] ?? 0)
                        </span></h5>
                        <h6>Alertas IA — En Riesgo</h6>
                    </div>
                </div>
            </div>
        </div>

        <!-- ====== Fila 2: Contadores de estado ====== -->
        <div class="row">
            <div class="col-lg-3 col-sm-6 col-12 d-flex">
                <div class="dash-count">
                    <div class="dash-counts">
                        <h4>@(ViewData["TotalInscritos"] ?? 0)</h4>
                        <h5>Inscritos</h5>
                    </div>
                    <div class="dash-imgs">
                        <i data-feather="users"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12 d-flex">
                <div class="dash-count das1">
                    <div class="dash-counts">
                        <h4>@(ViewData["TotalAprobados"] ?? 0)</h4>
                        <h5>Aprobados</h5>
                    </div>
                    <div class="dash-imgs">
                        <i data-feather="check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12 d-flex">
                <div class="dash-count das2">
                    <div class="dash-counts">
                        <h4>@(ViewData["TotalReprobados"] ?? 0)</h4>
                        <h5>Reprobados</h5>
                    </div>
                    <div class="dash-imgs">
                        <i data-feather="x-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-sm-6 col-12 d-flex">
                <div class="dash-count das3">
                    <div class="dash-counts">
                        <h4>@(ViewData["TotalEnRiesgoIA"] ?? 0)</h4>
                        <h5>En Riesgo (IA)</h5>
                    </div>
                    <div class="dash-imgs">
                        <i data-feather="alert-triangle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- ====== Fila 3: Gráfica de rendimiento + Tabla estudiantes recientes ====== -->
        <div class="row">
            <!-- Gráfica de Rendimiento Académico -->
            <div class="col-lg-7 col-sm-12 col-12 d-flex">
                <div class="card flex-fill">
                    <div class="card-header pb-0 d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Rendimiento Académico</h5>
                        <div class="graph-sets">
                            <ul>
                                <li><span>Aprobados</span></li>
                                <li><span>Reprobados</span></li>
                            </ul>
                            <div class="dropdown">
                                <button class="btn btn-white btn-sm dropdown-toggle" type="button"
                                        id="dropdownPeriodo" data-bs-toggle="dropdown" aria-expanded="false">
                                    2026 <img src="~/img/icons/dropdown.svg" alt="img" class="ms-2">
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="dropdownPeriodo">
                                    <li><a href="javascript:void(0);" class="dropdown-item">2026</a></li>
                                    <li><a href="javascript:void(0);" class="dropdown-item">2025</a></li>
                                    <li><a href="javascript:void(0);" class="dropdown-item">2024</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div id="rendimiento_charts"></div>
                    </div>
                </div>
            </div>

            <!-- Tabla: Estudiantes Registrados Recientemente -->
            <div class="col-lg-5 col-sm-12 col-12 d-flex">
                <div class="card flex-fill">
                    <div class="card-header pb-0 d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0">Estudiantes Recientes</h4>
                        <div class="dropdown">
                            <a href="javascript:void(0);" data-bs-toggle="dropdown"
                               aria-expanded="false" class="dropset">
                                <i class="fa fa-ellipsis-v"></i>
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="dropdownEstudiantes">
                                <li>
                                    <a asp-controller="Estudiantes" asp-action="Index" class="dropdown-item">
                                        Ver todos
                                    </a>
                                </li>
                                <li>
                                    <a asp-controller="Estudiantes" asp-action="Registro" class="dropdown-item">
                                        Registrar nuevo
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive dataview">
                            <table class="table datatable">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Estudiante</th>
                                        <th>Promedio</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (ViewData["EstudiantesRecientes"] is IEnumerable<dynamic> lista && lista.Any())
                                    {
                                        int i = 1;
                                        foreach (var est in lista)
                                        {
                                            <tr>
                                                <td>@i</td>
                                                <td>@est.Nombre</td>
                                                <td>@est.Promedio.ToString("F2")</td>
                                                <td>
                                                    <span class="badges @(est.Estado == "Aprobado" ? "bg-lightgreen" : "bg-lightred")">
                                                        @est.Estado
                                                    </span>
                                                </td>
                                            </tr>
                                            i++;
                                        }
                                    }
                                    else
                                    {
                                        <!-- Datos de ejemplo mientras no hay registros reales -->
                                        <tr>
                                            <td>1</td>
                                            <td>María García</td>
                                            <td>88.50</td>
                                            <td><span class="badges bg-lightgreen">Aprobado</span></td>
                                        </tr>
                                        <tr>
                                            <td>2</td>
                                            <td>Carlos López</td>
                                            <td>55.00</td>
                                            <td><span class="badges bg-lightred">Reprobado</span></td>
                                        </tr>
                                        <tr>
                                            <td>3</td>
                                            <td>Ana Martínez</td>
                                            <td>72.75</td>
                                            <td><span class="badges bg-lightgreen">Aprobado</span></td>
                                        </tr>
                                        <tr>
                                            <td>4</td>
                                            <td>Luis Hernández</td>
                                            <td>45.25</td>
                                            <td><span class="badges bg-lightred">Reprobado</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ====== Fila 4: Tabla de Estudiantes en Riesgo (Alertas IA) ====== -->
        <div class="card mb-0">
            <div class="card-body">
                <h4 class="card-title">
                    <i data-feather="alert-triangle" class="me-2" style="color:#ff4d4d;"></i>
                    Alertas IA — Estudiantes en Riesgo de Reprobar
                </h4>
                <div class="table-responsive dataview">
                    <table class="table datatable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Nota 1</th>
                                <th>Nota 2</th>
                                <th>Promedio</th>
                                <th>Predicción IA</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewData["EstudiantesRiesgo"] is IEnumerable<dynamic> riesgo && riesgo.Any())
                            {
                                int j = 1;
                                foreach (var est in riesgo)
                                {
                                    <tr>
                                        <td>@j</td>
                                        <td>@est.Nombre</td>
                                        <td>@est.Correo</td>
                                        <td>@est.Nota1</td>
                                        <td>@est.Nota2</td>
                                        <td>@est.Promedio.ToString("F2")</td>
                                        <td>
                                            <span class="badges bg-lightred">
                                                <i data-feather="alert-circle" class="me-1"></i> En Riesgo
                                            </span>
                                        </td>
                                    </tr>
                                    j++;
                                }
                            }
                            else
                            {
                                <!-- Datos de ejemplo mientras no hay registros reales -->
                                <tr>
                                    <td>1</td>
                                    <td>Carlos López</td>
                                    <td>carlos@email.com</td>
                                    <td>50</td>
                                    <td>60</td>
                                    <td>55.00</td>
                                    <td><span class="badges bg-lightred"><i data-feather="alert-circle" class="me-1"></i> En Riesgo</span></td>
                                </tr>
                                <tr>
                                    <td>2</td>
                                    <td>Luis Hernández</td>
                                    <td>luis@email.com</td>
                                    <td>40</td>
                                    <td>50</td>
                                    <td>45.00</td>
                                    <td><span class="badges bg-lightred"><i data-feather="alert-circle" class="me-1"></i> En Riesgo</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // Gráfica de rendimiento académico con ApexCharts
    var options = {
        series: [
            {
                name: 'Aprobados',
                data: [30, 40, 35, 50, 49, 60, 70, 91, 125]
            },
            {
                name: 'Reprobados',
                data: [8, 12, 10, 18, 15, 22, 20, 30, 40]
            }
        ],
        chart: {
            type: 'bar',
            height: 250,
            toolbar: { show: false }
        },
        colors: ['#28a745', '#ff4d4d'],
        plotOptions: {
            bar: {
                horizontal: false,
                columnWidth: '55%',
                borderRadius: 4
            }
        },
        dataLabels: { enabled: false },
        xaxis: {
            categories: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep']
        },
        legend: {
            position: 'top',
            horizontalAlign: 'left'
        }
    };

    var chart = new ApexCharts(document.querySelector("#rendimiento_charts"), options);
    chart.render();
</script>
}
