<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduPath AI</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/animate.css" />

    <link rel="stylesheet" href="~/plugins/icons/feather/feather.css" />
    <link rel="stylesheet" href="~/plugins/fontawesome/css/all.min.css" />
    <link rel="stylesheet" href="~/css/style.css" />
    <link rel="stylesheet" href="~/css/edupath-admin.css" />
    <link rel="stylesheet" href="~/css/edupath-vistas.css" />
    <link rel="stylesheet" href="~/css/layout/layout.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@{
    // Si la vista pasa un ViewModel que hereda de LayoutViewModel,
    // los datos del perfil se leen desde el modelo


    var perfil     = Model as Proyecto_Evaluacion_Estudiantes.Models.LayoutViewModel;
    bool esAdmin   = perfil?.EsAdmin   ?? (ViewData["EsAdmin"] is bool b && b);
    string nombre  = perfil?.NombreUsuario ?? ViewData["NombreDocente"]?.ToString() ?? "Usuario";
    string titulo  = perfil?.TituloUsuario ?? ViewData["TituloDocente"]?.ToString() ?? "Docente";
    string codigo  = perfil?.CodigoUsuario ?? ViewData["CodigoDocente"]?.ToString() ?? "---";
    string sistema = perfil?.Sistema       ?? ViewData["CursoActual"]?.ToString()   ?? "EduPath AI";
    string periodo = perfil?.Periodo       ?? ViewData["Periodo"]?.ToString()       ?? Proyecto_Evaluacion_Estudiantes.Helpers.PeriodoAcademico.ObtenerPeriodoDescriptivo();
    string menu    = perfil?.ActiveMenu    ?? ViewData["ActiveMenu"]?.ToString()    ?? "";

    var partes     = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    string iniciales = partes.Length >= 2
        ? $"{partes[0][0]}{partes[1][0]}".ToUpper()
        : nombre.Length >= 2 ? nombre[..2].ToUpper() : nombre.ToUpper();
    string avatarColor = esAdmin ? "#7c3aed" : "#0096c7";
}
    <div class="main-wrapper">

        <div class="header">
            <div class="header-left active">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <img src="~/img/Logo-EdupathAI.png" alt="EduPath AI" class="header-logo-full">
                </a>
            </div>

            <a id="mobile_btn" class="mobile_btn" href="#sidebar">
                <span class="bar-icon">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </a>

            <ul class="nav user-menu">
                <li class="nav-item dropdown" id="noti-dropdown">
                    <a href="javascript:void(0);" class="dropdown-toggle nav-link" data-bs-toggle="dropdown" id="noti-toggle">
                        <i class="fa fa-bell layout-bell-icon"></i>
                        <span class="badge rounded-pill bg-primary" id="noti-badge" style="display:none;">1</span>
                    </a>
                    <div class="dropdown-menu notifications">
                        <div class="topnav-dropdown-header">
                            <span class="notification-title">Notificaciones</span>
                            <a href="javascript:void(0)" class="clear-noti" id="noti-clear"> Limpiar Todo </a>
                        </div>
                        <div class="noti-content">
                            <ul class="notification-list" id="noti-list">
                                <li class="notification-message" id="noti-welcome">
                                    <a href="javascript:void(0);">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0 layout-noti-avatar">
                                                <i class="fa fa-user"></i>
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details">
                                                    ¡Bienvenido de vuelta, <span class="noti-title">@nombre</span>!
                                                    Tu sesión está activa en EduPath AI.
                                                </p>
                                                <p class="noti-time"><span class="notification-time" id="noti-time-label">Ahora</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                                <li class="notification-message text-center text-muted py-2" id="noti-empty" style="display:none;">
                                    <small>No hay notificaciones</small>
                                </li>
                            </ul>
                        </div>
                    </div>
                </li>

                <li class="nav-item dropdown has-arrow main-drop">
                    <a href="javascript:void(0);" class="dropdown-toggle nav-link userset" data-bs-toggle="dropdown">
                        <span class="user-img">
                            <span class="layout-avatar layout-avatar--nav" style="--avatar-bg:@avatarColor">
                                @iniciales
                            </span>
                            <span class="status online"></span>
                        </span>
                    </a>
                    <div class="dropdown-menu menu-drop-user">
                        <div class="profilename">
                            <div class="profileset">
                                <span class="user-img">
                                    <span class="layout-avatar layout-avatar--nav" style="--avatar-bg:@avatarColor">
                                        @iniciales
                                    </span>
                                    <span class="status online"></span>
                                </span>
                                <div class="profilesets">
                                    <h6>@nombre</h6>
                                    <h5>@titulo</h5>
                                </div>
                            </div>
                            <hr class="m-0">
                            <a class="dropdown-item" asp-controller="Home" asp-action="Perfil"><i class="me-2" data-feather="user"></i> Mi Perfil</a>
                            <hr class="m-0">
                            <a class="dropdown-item logout pb-0" asp-controller="Home" asp-action="CerrarSesion"><img src="~/img/icons/log-out.svg" class="me-2" alt="img">Cerrar Sesión</a>
                        </div>
                    </div>
                </li>
            </ul>

            <div class="dropdown mobile-user-menu">
                <a href="javascript:void(0);" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                <div class="dropdown-menu dropdown-menu-right">
                    <a class="dropdown-item" asp-controller="Home" asp-action="Perfil"><i class="me-2" data-feather="user"></i> Mi Perfil</a>
                    <a class="dropdown-item" asp-controller="Home" asp-action="CerrarSesion"><img src="~/img/icons/log-out.svg" class="me-2" alt="img">Cerrar Sesión</a>
                </div>
            </div>
        </div>



        <div class="sidebar" id="sidebar">
            <div class="sidebar-inner slimscroll">
                <div class="sidebar-profile">
                    <div class="d-flex align-items-center mb-2">
                        <span class="user-img me-2 layout-sidebar-img">
                            <span class="layout-avatar layout-avatar--sidebar" style="--avatar-bg:@avatarColor">
                                @iniciales
                            </span>
                            <span class="layout-sidebar-online-dot"></span>
                        </span>
                        <div class="layout-profile-text">
                            <h6 class="layout-profile-name">@nombre</h6>
                            <span class="layout-profile-role">@titulo</span>
                        </div>
                    </div>
                    <div class="layout-profile-info">
                        <div>
                            <i class="fa fa-id-badge layout-info-icon"></i>
                            <strong class="layout-info-label"> Cód:</strong>
                            <span class="layout-info-value">@codigo</span>
                        </div>
                        <div>
                            <i class="fa fa-graduation-cap layout-info-icon"></i>
                            <strong class="layout-info-label"> Sistema:</strong>
                            <span class="layout-info-value">@sistema</span>
                        </div>
                        <div>
                            <i class="fa fa-calendar layout-info-icon"></i>
                            <strong class="layout-info-label"> Periodo:</strong>
                            <span class="layout-info-value">@periodo</span>
                        </div>
                    </div>
                </div>

                <!-- Menú lateral -->
                <div id="sidebar-menu" class="sidebar-menu">
                    <ul>

                        @if (!esAdmin)
                        {
                            <li class="@(menu == "Dashboard" ? "active" : "")">
                                <a asp-controller="Home" asp-action="Index">
                                    <img src="~/img/icons/dashboard.svg" alt="img">
                                    <span> Dashboard</span>
                                </a>
                            </li>

                            <li class="submenu @(menu == "Informacion" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/users1.svg" alt="img">
                                    <span> Información</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="Registro">
                                            <i data-feather="user-plus" class="me-1"></i> Registrar Estudiante
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="Index">
                                            <i data-feather="list" class="me-1"></i> Lista de Estudiantes
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="submenu @(menu == "Notas" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/time.svg" alt="img">
                                    <span> Subir Notas</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="SubirNotas">
                                            <i data-feather="upload" class="me-1"></i> Ingresar Calificaciones
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="RegistroNotas">
                                            <i data-feather="edit-3" class="me-1"></i> Nota Rápida (por alumno)
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            
                            <li class="submenu @(menu == "Reportes" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/time.svg" alt="img">
                                    <span> Reportes</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Reportes" asp-action="General">
                                            <i data-feather="bar-chart-2" class="me-1"></i> Reporte Académico General
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Reportes" asp-action="Riesgo">
                                            <i data-feather="alert-triangle" class="me-1"></i> Estudiantes en Riesgo
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <li class="submenu @(menu == "Prediccion" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <i class="fa fa-brain layout-menu-icon"></i>
                                    <span> Análisis IA</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Prediccion" asp-action="Buscar">
                                            <i data-feather="cpu" class="me-1"></i> Predicción de Riesgo
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        @if (esAdmin)
                        {
                            <!-- Administrador (solo para rol Admin) -->
                            <li class="submenu @(menu == "Administrador" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/users1.svg" alt="img">
                                    <span> Administrador</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionUsuarios">
                                            <i data-feather="user-check" class="me-1"></i> Configuración de Usuarios
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionAdministradores">
                                            <i data-feather="shield" class="me-1"></i> Configuración de Administradores
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Configuración Académica (solo Admin) -->
                            <li class="submenu @(menu == "Academica" ? "active" : "")"
                                data-menu-id="Academica">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/time.svg" alt="img">
                                    <span> Config. Académica</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionGrados">
                                            <i data-feather="layers" class="me-1"></i> Grados
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionAsignaturas">
                                            <i data-feather="book-open" class="me-1"></i> Asignaturas
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Gestión de Cursos (solo Admin) -->
                            <li class="submenu @(menu == "Cursos" ? "active" : "")"
                                data-menu-id="Cursos">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/product.svg" alt="img">
                                    <span> Gestión de Cursos</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="GestionCursos">
                                            <i data-feather="grid" class="me-1"></i> Cursos
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="AsignacionDocentes">
                                            <i data-feather="user-check" class="me-1"></i> Asignacion de Docentes
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

            
                        <li class="submenu @(menu == "Configuracion" ? "active" : "")">
                            <a href="javascript:void(0);">
                                <img src="~/img/icons/settings.svg" alt="img">
                                <span> Configuración</span>
                                <span class="menu-arrow"></span>
                            </a>
                            <ul>
                                @if (!esAdmin)
                                {
                                    <li>
                                        <a asp-controller="Home" asp-action="Perfil">
                                            <i data-feather="user" class="me-1"></i> Mi Perfil
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a asp-controller="Home" asp-action="CerrarSesion">
                                        <i data-feather="log-out" class="me-1"></i> Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </div>
            </div>
        </div>

        @RenderBody()

    </div>


    <script src="~/js/jquery-3.6.0.min.js"></script>
    <script src="~/js/feather.min.js"></script>
    <script src="~/js/jquery.slimscroll.min.js"></script>
    <script src="~/js/jquery.dataTables.min.js"></script>
    <script src="~/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/plugins/apexchart/apexcharts.min.js"></script>
    <script src="~/plugins/apexchart/chart-data.js"></script>
    <script src="~/js/script.js"></script>

    <script>
        var _esAdmin    = @(esAdmin.ToString().ToLower());
        var _menuActivo = '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(menu)';

    $(document).ready(function () {

        $('#sidebar-menu a').off('click');

        // Toggle: clic en el <a> cabecera de cada li.submenu
        $('#sidebar-menu li.submenu > a').on('click', function (e) {
            e.preventDefault();
            var $a  = $(this);
            var $ul = $a.next('ul');

            if ($a.hasClass('subdrop')) {
                $a.removeClass('subdrop');
                $ul.slideUp(250);
            } else {
         
                $('#sidebar-menu li.submenu > a.subdrop').not($a).removeClass('subdrop')
                    .next('ul').slideUp(250);

                $a.addClass('subdrop');
                $ul.slideDown(250);
            }
        });

        // Marcar activo el ítem que corresponde al menú actual
        $('#sidebar-menu li').removeClass('active');
        if (_menuActivo) {
            $('#sidebar-menu li[data-menu="' + _menuActivo + '"]').addClass('active');
        }

        if (window.feather) feather.replace();

    });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
    (function () {
        var SESSION_KEY = 'edupath_noti_cleared_@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(nombre)';
        var READ_KEY    = 'edupath_noti_read_@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(nombre)';

        var $badge   = $('#noti-badge');
        var $welcome = $('#noti-welcome');
        var $empty   = $('#noti-empty');
        var $toggle  = $('#noti-toggle');
        var $clear   = $('#noti-clear');

        function isCleared() { return sessionStorage.getItem(SESSION_KEY) === '1'; }
        function isRead()    { return sessionStorage.getItem(READ_KEY)    === '1'; }

        function renderState() {
            if (isCleared()) {
                $welcome.hide();
                $empty.show();
                $badge.hide();
            } else {
                $welcome.show();
                $empty.hide();
                $badge.toggle(!isRead());
            }
        }

        $toggle.on('click', function () {
            if (!isCleared()) {
                sessionStorage.setItem(READ_KEY, '1');
                $badge.hide();
            }
        });

        
        $clear.on('click', function () {
            sessionStorage.setItem(SESSION_KEY, '1');
            renderState();
            $toggle.dropdown('hide');
        });

        renderState();


        if (!isCleared()) {
            var loginTime = sessionStorage.getItem('edupath_login_time');
            if (!loginTime) {
                loginTime = Date.now();
                sessionStorage.setItem('edupath_login_time', loginTime);
            }
            var diff = Math.floor((Date.now() - parseInt(loginTime)) / 60000);
            var label = diff < 1 ? 'Hace un momento' : 'Hace ' + diff + ' min';
            $('#noti-time-label').text(label);
        }
    })();
    </script>

</body>
</html>
