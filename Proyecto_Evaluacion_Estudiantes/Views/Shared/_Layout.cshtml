<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EduPath AI</title>

    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/animate.css" />
    <!-- Feather Icons -->
    <link rel="stylesheet" href="~/plugins/icons/feather/feather.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/plugins/fontawesome/css/all.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="~/css/dataTables.bootstrap4.min.css" />
    <!-- Template Main CSS -->
    <link rel="stylesheet" href="~/css/style.css" />
    <!-- EduPath AI Admin Styles -->
    <link rel="stylesheet" href="~/css/edupath-admin.css" />
</head>
<body>
@{
    // Si la vista pasa un ViewModel que hereda de LayoutViewModel,
    // los datos del perfil se leen desde el modelo (patrón MVC fuerte).
    // Cuando la vista usa un modelo de entidad (Docente, Administrador),
    // el layout recae en el ViewData que el controlador ya establece.
    var perfil     = Model as Proyecto_Evaluacion_Estudiantes.Models.LayoutViewModel;
    bool esAdmin   = perfil?.EsAdmin   ?? (ViewData["EsAdmin"] is bool b && b);
    string nombre  = perfil?.NombreUsuario ?? ViewData["NombreDocente"]?.ToString() ?? "Usuario";
    string titulo  = perfil?.TituloUsuario ?? ViewData["TituloDocente"]?.ToString() ?? "Docente";
    string codigo  = perfil?.CodigoUsuario ?? ViewData["CodigoDocente"]?.ToString() ?? "---";
    string sistema = perfil?.Sistema       ?? ViewData["CursoActual"]?.ToString()   ?? "EduPath AI";
    string periodo = perfil?.Periodo       ?? ViewData["Periodo"]?.ToString()       ?? "2026-1";
    string menu    = perfil?.ActiveMenu    ?? ViewData["ActiveMenu"]?.ToString()    ?? "";
}
    <div class="main-wrapper">

        <!-- Header -->
        <div class="header">
            <div class="header-left active">
                <a asp-controller="Home" asp-action="Index" class="logo">
                    <img src="~/img/logoInstitucional.png" alt="EduPath AI" style="max-height:42px;width:auto;">
                </a>
                <a asp-controller="Home" asp-action="Index" class="logo-small">
                    <img src="~/img/logoInstitucional.png" alt="EduPath AI" style="max-height:36px;width:auto;">
                </a>
                <a id="toggle_btn" href="javascript:void(0);"></a>
            </div>

            <a id="mobile_btn" class="mobile_btn" href="#sidebar">
                <span class="bar-icon">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
            </a>

            <ul class="nav user-menu">
                <li class="nav-item">
                    <div class="top-nav-search">
                        <a href="javascript:void(0);" class="responsive-search">
                            <i class="fa fa-search"></i>
                        </a>
                        <form action="#">
                            <div class="searchinputs">
                                <input type="text" placeholder="Search Here ...">
                                <div class="search-addon">
                                    <span><img src="~/img/icons/closes.svg" alt="img"></span>
                                </div>
                            </div>
                            <a class="btn" id="searchdiv"><img src="~/img/icons/search.svg" alt="img"></a>
                        </form>
                    </div>
                </li>

                <li class="nav-item dropdown">
                    <a href="javascript:void(0);" class="dropdown-toggle nav-link" data-bs-toggle="dropdown">
                        <img src="~/img/icons/notification-bing.svg" alt="img"> <span class="badge rounded-pill">4</span>
                    </a>
                    <div class="dropdown-menu notifications">
                        <div class="topnav-dropdown-header">
                            <span class="notification-title">Notifications</span>
                            <a href="javascript:void(0)" class="clear-noti"> Clear All </a>
                        </div>
                        <div class="noti-content">
                            <ul class="notification-list">
                                <li class="notification-message">
                                    <a href="activities.html">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0">
                                                <img alt="" src="~/img/profiles/avatar-02.jpg">
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details"><span class="noti-title">John Doe</span> added new task <span class="noti-title">Patient appointment booking</span></p>
                                                <p class="noti-time"><span class="notification-time">4 mins ago</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                                <li class="notification-message">
                                    <a href="activities.html">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0">
                                                <img alt="" src="~/img/profiles/avatar-03.jpg">
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details"><span class="noti-title">Tarah Shropshire</span> changed the task name <span class="noti-title">Appointment booking with payment gateway</span></p>
                                                <p class="noti-time"><span class="notification-time">6 mins ago</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                                <li class="notification-message">
                                    <a href="activities.html">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0">
                                                <img alt="" src="~/img/profiles/avatar-06.jpg">
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details"><span class="noti-title">Misty Tison</span> added <span class="noti-title">Domenic Houston</span> and <span class="noti-title">Claire Mapes</span> to project <span class="noti-title">Doctor available module</span></p>
                                                <p class="noti-time"><span class="notification-time">8 mins ago</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                                <li class="notification-message">
                                    <a href="activities.html">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0">
                                                <img alt="" src="~/img/profiles/avatar-17.jpg">
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details"><span class="noti-title">Rolland Webber</span> completed task <span class="noti-title">Patient and Doctor video conferencing</span></p>
                                                <p class="noti-time"><span class="notification-time">12 mins ago</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                                <li class="notification-message">
                                    <a href="activities.html">
                                        <div class="media d-flex">
                                            <span class="avatar flex-shrink-0">
                                                <img alt="" src="~/img/profiles/avatar-13.jpg">
                                            </span>
                                            <div class="media-body flex-grow-1">
                                                <p class="noti-details"><span class="noti-title">Bernardo Galaviz</span> added new task <span class="noti-title">Private chat module</span></p>
                                                <p class="noti-time"><span class="notification-time">2 days ago</span></p>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="topnav-dropdown-footer">
                            <a href="activities.html">View all Notifications</a>
                        </div>
                    </div>
                </li>

                <li class="nav-item dropdown has-arrow main-drop">
                    <a href="javascript:void(0);" class="dropdown-toggle nav-link userset" data-bs-toggle="dropdown">
                        <span class="user-img">
                            <img src="~/img/logoInstitucional.png" alt="">
                            <span class="status online"></span>
                        </span>
                    </a>
                    <div class="dropdown-menu menu-drop-user">
                        <div class="profilename">
                            <div class="profileset">
                                <span class="user-img">
                                    <img src="~/img/logoInstitucional.png" alt="">
                                    <span class="status online"></span>
                                </span>
                                <div class="profilesets">
                                    <h6>@nombre</h6>
                                    <h5>@titulo</h5>
                                </div>
                            </div>
                            <hr class="m-0">
                            <a class="dropdown-item" asp-controller="Home" asp-action="Perfil"><i class="me-2" data-feather="user"></i> Mi Perfil</a>
                            <hr class="m-0">
                            <a class="dropdown-item logout pb-0" asp-controller="Home" asp-action="IniciarSesion"><img src="~/img/icons/log-out.svg" class="me-2" alt="img">Cerrar Sesión</a>
                        </div>
                    </div>
                </li>
            </ul>

            <div class="dropdown mobile-user-menu">
                <a href="javascript:void(0);" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false"><i class="fa fa-ellipsis-v"></i></a>
                <div class="dropdown-menu dropdown-menu-right">
                    <a class="dropdown-item" href="profile.html">My Profile</a>
                    <a class="dropdown-item" href="generalsettings.html">Settings</a>
                    <a class="dropdown-item" href="signin.html">Logout</a>
                </div>
            </div>
        </div>

        <div class="sidebar" id="sidebar">
            <div class="sidebar-inner slimscroll">
                <div class="sidebar-profile" style="padding:18px 16px 14px;border-bottom:2px solid rgba(0,180,216,0.25);background:linear-gradient(135deg,#0d1b2a 0%,#1a3a5c 100%);">
                    <div class="d-flex align-items-center mb-2">
                        <span class="user-img me-2" style="position:relative;">
                            <img src="~/img/logoInstitucional.png" alt="Usuario"
                                 style="width:44px;height:44px;border-radius:50%;border:2px solid #00b4d8;object-fit:cover;">
                            <span style="position:absolute;bottom:1px;right:1px;width:10px;height:10px;
                                         background:#00b894;border-radius:50%;border:2px solid #0d1b2a;"></span>
                        </span>
                        <div style="overflow:hidden;">
                            <h6 style="color:#fff;font-size:13px;font-weight:700;margin:0;
                                       line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @nombre
                            </h6>
                            <span style="color:#48cae4;font-size:11px;font-weight:600;letter-spacing:.3px;">
                                @titulo
                            </span>
                        </div>
                    </div>
                    <div style="font-size:11px;color:rgba(255,255,255,0.65);line-height:2;margin-top:4px;">
                        <div>
                            <i class="fa fa-id-badge" style="color:#48cae4;width:14px;text-align:center;"></i>
                            <strong style="color:rgba(255,255,255,0.9);"> Cód:</strong>
                            <span style="color:#fff;">@codigo</span>
                        </div>
                        <div>
                            <i class="fa fa-graduation-cap" style="color:#48cae4;width:14px;text-align:center;"></i>
                            <strong style="color:rgba(255,255,255,0.9);"> Sistema:</strong>
                            <span style="color:#fff;">@sistema</span>
                        </div>
                        <div>
                            <i class="fa fa-calendar" style="color:#48cae4;width:14px;text-align:center;"></i>
                            <strong style="color:rgba(255,255,255,0.9);"> Periodo:</strong>
                            <span style="color:#fff;">@periodo</span>
                        </div>
                    </div>
                </div>





                <!-- Menú lateral -->


                <div id="sidebar-menu" class="sidebar-menu">
                    <ul>

                        @if (!esAdmin)
                        {
                            <!-- Dashboard (solo docentes) -->
                            <li class="@(menu == "Dashboard" ? "active" : "")">
                                <a asp-controller="Home" asp-action="Index">
                                    <img src="~/img/icons/dashboard.svg" alt="img">
                                    <span> Dashboard</span>
                                </a>
                            </li>

                            <li class="submenu @(menu == "Informacion" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/users1.svg" alt="img">
                                    <span> Información</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="Registro">
                                            <i data-feather="user-plus" class="me-1"></i> Registrar Estudiante
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="Index">
                                            <i data-feather="list" class="me-1"></i> Lista de Estudiantes
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Estudiantes" asp-action="Prediccion">
                                            <i data-feather="cpu" class="me-1"></i> Predicción IA (Riesgo)
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            <!-- Reportes -->
                            <li class="submenu @(menu == "Reportes" ? "active" : "")"  >
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/time.svg" alt="img">
                                    <span> Reportes</span>
                                    <span class="menu-arrow"></span>
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Reportes" asp-action="General">
                                            <i data-feather="bar-chart-2" class="me-1"></i> Reporte Académico General
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Reportes" asp-action="Riesgo">
                                            <i data-feather="alert-triangle" class="me-1"></i> Estudiantes en Riesgo
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }





                        <!-- Codigo modificado por el diseño-->
                        @if (esAdmin)
                        {
                            <!-- Administrador (solo para rol Admin) -->
                            <li class="submenu @(menu == "Administrador" ? "active" : "")">
                                <a href="javascript:void(0);">
                                    <img src="~/img/icons/users1.svg" alt="img">
                                    <span> Administrador</span>
                                    <span class="menu-arrow"></span>  
                                </a>
                                <ul>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionUsuarios">
                                            <i data-feather="shield"></i> Configuración de Usuarios
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionAdministradores">
                                            <i data-feather="shield"></i> Configuración de Administradores
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Administradores" asp-action="ConfiguracionCursos">
                                            <i data-feather="book-open"></i> Configuración de Cursos
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Configuración (visible para todos) -->
                        <li class="submenu @(menu == "Configuracion" ? "active" : "")">
                            <a href="javascript:void(0);">
                                <img src="~/img/icons/settings.svg" alt="img">
                                <span> Configuración</span>
                                <span class="menu-arrow"></span>
                            </a>
                            <ul>
                                @if (!esAdmin)
                                {
                                    <li>
                                        <a asp-controller="Home" asp-action="Perfil">
                                            <i data-feather="user" class="me-1"></i> Mi Perfil
                                        </a>
                                    </li>
                                }
                                <li>
                                    <a asp-controller="Home" asp-action="CerrarSesion">
                                        <i data-feather="log-out" class="me-1"></i> Cerrar Sesión
                                    </a>
                                </li>
                            </ul>
                        </li>

                    </ul>
                </div>
            </div>
        </div>
        <!-- /Sidebar -->
        <!-- Page Content -->
        @RenderBody()
        <!-- /Page Content -->

    </div>
    <!-- /main-wrapper -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/jquery-3.6.0.min.js"></script>
    <script src="~/js/feather.min.js"></script>
    <script src="~/js/jquery.slimscroll.min.js"></script>
    <script src="~/js/jquery.dataTables.min.js"></script>
    <script src="~/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/plugins/apexchart/apexcharts.min.js"></script>
    <script src="~/plugins/apexchart/chart-data.js"></script>
    <script src="~/js/script.js"></script>

    <script>
    var _esAdmin = @(esAdmin.ToString().ToLower());   // true | false
    var _menuActivo = '@menu';                        // "Dashboard" | "Informacion" | "Administrador" ...

    $(document).ready(function () {

        // 1. Iconos Feather
        //if (window.feather) feather.replace();

        // 2. Abrir el submenú que corresponda según rol y página actual
        //    Este bloque corre DESPUÉS del script.js del template, por lo que
        //    sobreescribe cualquier colapso automático que haga el template.
        abrirSubmenuActivo();

        // 3. Feather en contenido dinámico (AJAX)
       // $(document).on('DOMNodeInserted', function () {
        //    if (window.feather) feather.replace();
       // });
    });

    function abrirSubmenuActivo() {
        // a) Abrir submenú marcado como "active" (cualquier rol, cualquier página)
        var $active = $('li.submenu.active');
        if ($active.length) {
            $active.addClass('subdrop').children('ul').css('display', 'block');
        }

        // b) Para DOCENTES: el submenú "Información" debe estar siempre abierto,
        //    independientemente de si estamos en Dashboard u otra página.
        //    Buscamos el li.submenu que contiene links a "/Estudiantes/".
        if (!_esAdmin) {
            $('li.submenu').each(function () {
                var $li = $(this);
                // Si algún <a> hijo apunta a Estudiantes, abrimos este submenú
                if ($li.find('a[href*="Estudiantes"]').length > 0) {
                    $li.addClass('subdrop').children('ul').css('display', 'block');
                }
            });
        }

        // c) Para ADMINS: abrir submenú "Administrador" cuando corresponda
        if (_esAdmin && ($('#sidebar-menu li.submenu.active').length === 0)) {
            $('li.submenu').first().addClass('subdrop').children('ul').css('display', 'block');
        }
    }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
