@model Proyecto_Evaluacion_Estudiantes.Models.Administrador
@{
    ViewData["Title"] = "Configuración de Administradores — EduPath AI";
    ViewData["ActiveMenu"] = "Administrador";
}

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="shield" style="color:#00b4d8;" class="me-2"></i>
                    Configuración de Administradores
                </h4>
                <h6>EduPath AI — Gestión de Cuentas de Administrador</h6>
            </div>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-edupath-success" role="alert">
                <i data-feather="check-circle" class="me-2" style="color:#00b4d8;"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2" style="color:#e17055;"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-4 pb-3" style="border-bottom:2px solid #e2e8f0;">
                    <div class="admin-stat-icon me-3"
                         style="background:linear-gradient(135deg,#0096c7,#48cae4);box-shadow:0 4px 12px rgba(0,150,199,.3);">
                        <i data-feather="shield" style="color:#fff;width:20px;height:20px;"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;color:#1a2b4a;font-weight:700;">Nuevo Administrador</h5>
                        <small class="text-muted">
                            El nombre de usuario se genera automáticamente. Mínimo 8 caracteres con al menos 2 dígitos.
                        </small>
                    </div>
                </div>

                <form asp-controller="Administradores" asp-action="ConfiguracionAdministradores" method="post">
                    @Html.AntiForgeryToken()


                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="user" class="me-1" style="color:#00b4d8;"></i>
                                @Html.DisplayNameFor(m => m.Nombre)
                            </label>
                            <input asp-for="Nombre" id="adm-Nombre"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: María" maxlength="200"
                                   oninput="generarUsuario()" />
                            <span asp-validation-for="Nombre" class="text-danger" style="font-size:12px;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="user" class="me-1" style="color:#00b4d8;"></i>
                                @Html.DisplayNameFor(m => m.Apellido)
                            </label>
                            <input asp-for="Apellido" id="adm-Apellido"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: González" maxlength="200"
                                   oninput="generarUsuario()" />
                            <span asp-validation-for="Apellido" class="text-danger" style="font-size:12px;"></span>
                        </div>
                    </div>


                    <div class="mb-3">
                        <label asp-for="NombreUsuario" class="form-label fw-semibold" style="color:#1a2b4a;">
                            <i data-feather="at-sign" class="me-1" style="color:#00b4d8;"></i>
                            @Html.DisplayNameFor(m => m.NombreUsuario)
                            <span class="badge-gen ms-2">Generado automáticamente</span>
                        </label>
                        <div class="input-group-adm">
                            <input asp-for="NombreUsuario" id="adm-Usuario"
                                   class="form-control form-control-edupath"
                                   placeholder="Se completará con nombre y apellido"
                                   maxlength="200" autocomplete="off" />
                            <button type="button" class="btn-regenerar" onclick="regenerarUsuario()"
                                    title="Generar nuevo usuario">
                                <i data-feather="refresh-cw" style="width:15px;height:15px;"></i>
                            </button>
                        </div>
                        <small id="adm-usuario-info" class="text-muted" style="font-size:11px;"></small>
                        <span asp-validation-for="NombreUsuario" class="text-danger d-block" style="font-size:12px;"></span>
                    </div>


                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="color:#1a2b4a;">
                            <i data-feather="lock" class="me-1" style="color:#00b4d8;"></i>
                            Contraseña
                        </label>
                        <input type="password" name="ContrasenaInput"
                               class="form-control"
                               placeholder="Mínimo 8 caracteres"
                               autocomplete="new-password" />
                        <span class="text-danger" style="font-size:12px;">
                            @Html.ValidationMessage("ContrasenaInput")
                        </span>
                    </div>


                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="Activo" class="form-check-label fw-semibold" style="color:#1a2b4a;">
                                Administrador activo en el sistema
                            </label>
                        </div>
                    </div>


                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Administradores" asp-action="Index"
                           class="btn-cancelar-form">
                            <i data-feather="x" style="width:14px;height:14px;"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-cfg-guardar">
                            <i data-feather="save" style="width:16px;height:16px;"></i>
                            Guardar Administrador
                        </button>
                    </div>

                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    let sufijo = generarSufijo();

    function generarSufijo() {
        return String(Math.floor(Math.random() * 90) + 10);
    }

    function normalizar(texto) {
        return texto.trim().toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
            .replace(/[^a-z0-9]/g, '');
    }

    function construirUsuario(nombre, apellido, suf) {
        const n = normalizar(nombre);
        const a = normalizar(apellido);
        if (!n && !a) return '';
        let base = (n.length > 0 ? n[0] : '') + a;
        const needed = Math.max(6, 8 - suf.length);
        if (base.length < needed) base = (n + a).substring(0, needed);
        const candidato = base + suf;
        return candidato.length < 8
            ? base.padEnd(8 - suf.length, a || n || 'x') + suf
            : candidato;
    }

    function generarUsuario() {
        const nombre   = document.getElementById('adm-Nombre').value;
        const apellido = document.getElementById('adm-Apellido').value;
        const usuario  = construirUsuario(nombre, apellido, sufijo);
        const input    = document.getElementById('adm-Usuario');
        const info     = document.getElementById('adm-usuario-info');
        input.value = usuario;
        if (usuario.length >= 8) {
            const digits = (usuario.match(/\d/g) || []).length;
            info.textContent = `✓ ${usuario.length} caracteres · ${digits} dígito(s)`;
            info.style.color = '#00b894';
        } else if (usuario) {
            info.textContent = '⚠ Agrega más nombre o apellido (mínimo 8 caracteres)';
            info.style.color = '#e17055';
        } else {
            info.textContent = '';
        }
    } 

    function regenerarUsuario() {
        sufijo = generarSufijo();
        generarUsuario();
    }

    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
        const usuario = document.getElementById('adm-Usuario').value;
        if (usuario) {
            const info   = document.getElementById('adm-usuario-info');
            const digits = (usuario.match(/\d/g) || []).length;
            info.textContent = `✓ ${usuario.length} caracteres · ${digits} dígito(s)`;
            info.style.color = '#00b894';
        }
    });
</script>
}
