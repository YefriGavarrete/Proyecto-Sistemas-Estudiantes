@model Proyecto_Evaluacion_Estudiantes.Models.GestionCursosViewModel
@{
    ViewData["Title"] = "Gestion de Cursos - EduPath AI";
    ViewData["ActiveMenu"] = "Cursos";
    bool editando = Model.EditandoId.HasValue;
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="grid" class="icon-page-header me-2"></i>
                    Gestion de Cursos
                </h4>
                <h6>EduPath AI - Registro de Cursos por Grado y Seccion</h6>
            </div>
            <div class="page-btn d-flex gap-2">
                <a asp-controller="Administradores" asp-action="AsignacionDocentes"
                   class="btn-nav-est">
                    <i data-feather="user-check"></i> Asignacion de Docentes
                </a>
            </div>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-edupath-success" role="alert">
                <i data-feather="check-circle" class="me-2 icon-primary"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2 icon-danger"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Formulario Crear / Editar -->
        <div class="card mb-4">
            <div class="card-body">

                <div class="d-flex align-items-center mb-4 pb-3 card-section-divider">
                    <div class="admin-stat-icon me-3 stat-icon-blue">
                        <i data-feather="@(editando ? "edit-2" : "plus-circle")" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">
                            @(editando ? "Editar Curso" : "Nuevo Curso")
                        </h5>
                        <small class="text-muted">
                            @(editando ? "Modificando datos del curso seleccionado. " : "Complete los datos para registrar un nuevo curso.")
                        </small>
                    </div>
                    @if (editando)
                    {
                        <a asp-controller="Administradores" asp-action="GestionCursos"
                           class="btn-cancelar-form ms-auto">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar edicion
                        </a>
                    }
                </div>

                <form asp-controller="Administradores"
                      asp-action="@(editando ? "EditarGestionCurso" : "GestionCursos")"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EditandoId" value="@Model.EditandoId" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="layers" class="me-1 icon-primary"></i>
                                Grado
                            </label>
                            <select name="FormGradoId" class="form-select" required>
                                <option value="">-- Seleccionar grado --</option>
                                @foreach (var item in Model.GradosItems)
                                {
                                    <option value="@item.Value"
                                            selected="@(item.Value == Model.FormGradoId?.ToString() ? "selected" : null)">
                                        @item.Text
                                    </option>
                                }
                            </select>
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormGradoId")
                            </span>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="tag" class="me-1 icon-primary"></i>
                                Seccion
                            </label>
                            <select name="FormSeccion" class="form-select" required>
                                <option value="">--</option>
                                @foreach (var sec in new[] { "A", "B", "C", "D", "E" })
                                {
                                    <option value="@sec"
                                            selected="@(Model.FormSeccion == sec ? "selected" : null)">
                                        @sec
                                    </option>
                                }
                            </select>
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormSeccion")
                            </span>
                        </div>


                        <div class="col-md-2">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="calendar" class="me-1 icon-primary"></i>
                                Periodo
                            </label>
                            <input name="FormPeriodo" value="@Model.FormPeriodo"
                                   class="form-control"
                                   placeholder="Ej: 2026"
                                   maxlength="20" required />
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormPeriodo")
                            </span>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="user-check" class="me-1 icon-primary"></i>
                                Docente Tutor
                            </label>
                            <select name="FormDocenteTutorId" class="form-select">
                                <option value="">-- Sin tutor asignado --</option>
                                @foreach (var item in Model.DocentesTutorItems)
                                {
                                    <option value="@item.Value"
                                            selected="@(item.Value == Model.FormDocenteTutorId?.ToString() ? "selected" : null)">
                                        @item.Text
                                    </option>
                                }
                            </select>
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormDocenteTutorId")
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input type="checkbox" name="FormActivo" value="true"
                                   class="form-check-input" role="switch"
                                   id="chkCursoActivo" @(Model.FormActivo ? "checked" : "") />
                            <input type="hidden" name="FormActivo" value="false" />
                            <label class="form-check-label fw-semibold label-form" for="chkCursoActivo">
                                Curso activo en el sistema
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Administradores" asp-action="Index"
                           class="btn-cancelar-form">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-cfg-guardar">
                            <i data-feather="save" class="icon-16sq"></i>
                            @(editando ? "Actualizar Curso" : "Guardar Curso")
                        </button>
                    </div>

                </form>
            </div>
        </div>


        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-3 pb-2 card-section-divider">
                    <div class="admin-stat-icon me-3 stat-icon-blue">
                        <i data-feather="list" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">Cursos Registrados</h5>
                        <small class="text-muted">Total: @Model.Cursos.Count curso(s)</small>
                    </div>
                </div>

                @if (!Model.Cursos.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i data-feather="inbox" class="icon-inbox-empty mb-3 d-block mx-auto"></i>
                        <p>No hay cursos registrados aun.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover" id="tbl-gestion-cursos">
                            <thead>
                                <tr>
                                    <th>Curso</th>
                                    <th class="w-col-80">Seccion</th>
                                    <th class="w-col-100">Periodo</th>
                                    <th>Docente Tutor</th>
                                    <th class="text-center w-col-90">Estado</th>
                                    <th class="text-center w-col-140">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Cursos)
                                {
                                    <tr class="@(c.Id == Model.EditandoId ? "table-info" : "")">
                                        <td>
                                            <strong class="text-dark-navy">
                                                @(c.Grado?.Nombre ?? $"Grado #{c.GradoId}")
                                            </strong>
                                        </td>
                                        <td>
                                            <span class="badge badge-gradient-blue-lg">
                                                Sec. @(c.Seccion ?? "?")
                                            </span>
                                        </td>
                                        <td>@c.Periodo</td>
                                        <td>
                                            @if (c.DocenteTutor != null)
                                            {
                                                <span>@c.DocenteTutor.Titulo @c.DocenteTutor.NombreCompleto</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Sin tutor</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (c.Activo)
                                            {
                                                <span class="badge badge-green">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-inactive">Inactivo</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center">

                                                <a asp-controller="Administradores"
                                                   asp-action="AsignacionDocentes"
                                                   asp-route-cursoId="@c.Id"
                                                   class="btn btn-sm btn-action-assign"
                                                   title="Asignar docentes">
                                                    <i data-feather="user-plus" class="icon-14sq"></i>
                                                </a>

                                                <a asp-controller="Administradores"
                                                   asp-action="GestionCursos"
                                                   asp-route-editarId="@c.Id"
                                                   class="btn btn-sm btn-action-edit-sm"
                                                   title="Editar">
                                                    <i data-feather="edit-2" class="icon-14sq"></i>
                                                </a>
                                                <!-- button de eliminar-->

                                                <form asp-controller="Administradores"
                                                      asp-action="EliminarGestionCurso"
                                                      method="post"
                                                      onsubmit="return confirm('Eliminar este curso?')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@c.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-action-delete-sm"
                                                            title="Eliminar">
                                                        <i data-feather="trash-2" class="icon-14sq"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();

        var tbl = document.getElementById('tbl-gestion-cursos');
        if (tbl && typeof $.fn.DataTable !== 'undefined' && !$.fn.DataTable.isDataTable('#tbl-gestion-cursos')) {
            $('#tbl-gestion-cursos').DataTable({
                language: {
                    search: "Buscar:",
                    zeroRecords: "No se encontraron cursos."
                },
                order: [[0, 'asc'], [1, 'asc']],
                paging: false,
                lengthChange: false,
                info: false
            });
        }
    });
    </script>
}
