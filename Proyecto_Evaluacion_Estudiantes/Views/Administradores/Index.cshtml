@model Proyecto_Evaluacion_Estudiantes.Models.AdminIndexViewModel
@{
    ViewData["Title"] = "Panel de Administrador — EduPath AI";
    ViewData["ActiveMenu"] = "Administrador";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="shield" class="icon-page-header me-2"></i>
                    Panel de Administrador
                </h4>
                <h6>EduPath AI — Centro de Control del Sistema</h6>
            </div>
        </div>


        <div class="card mb-4 card-border-primary">
            <div class="card-body d-flex align-items-center gap-3 py-3">
                <div class="admin-stat-icon stat-icon-blue-lg">
                    <i data-feather="user-check" class="icon-stat-24w"></i>
                </div>
                <div>
                    <h5 class="text-admin-welcome mb-0">
                        Bienvenido, @Model.NombreAdmin
                    </h5>
                    <small class="text-muted">
                        Tienes acceso completo al sistema EduPath AI. Periodo: @Model.Periodo
                    </small>
                </div>
            </div>
        </div>

        <!-- Tarjetas de resumen -->
        <div class="row g-3 mb-4">

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card admin-stat-card-blue">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="admin-stat-label">Administradores Activos</p>
                            <h3 class="admin-stat-value">@Model.TotalAdmins</h3>
                        </div>
                        <div class="admin-stat-icon stat-icon-blue">
                            <i data-feather="shield" class="icon-stat-22w"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card admin-stat-card-lblue">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="admin-stat-label">Docentes Registrados</p>
                            <h3 class="admin-stat-value">@Model.TotalDocentes</h3>
                        </div>
                        <div class="admin-stat-icon stat-icon-lblue">
                            <i data-feather="users" class="icon-stat-22w"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card admin-stat-card-green">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="admin-stat-label">Módulo Predicción IA</p>
                            <h3 class="admin-stat-value-sm stat-value-green">Activo</h3>
                        </div>
                        <div class="admin-stat-icon stat-icon-green">
                            <i data-feather="cpu" class="icon-stat-22w"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-xl-3">
                <div class="admin-stat-card admin-stat-card-yellow">
                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <p class="admin-stat-label">Periodo Actual</p>
                            <h3 class="admin-stat-value-sm stat-value-period">@Model.Periodo</h3>
                        </div>
                        <div class="admin-stat-icon stat-icon-yellow">
                            <i data-feather="calendar" class="icon-stat-period"></i>
                        </div>
                    </div>
                </div>
            </div>

        </div>


        <div class="row g-3">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-section-title mb-3">
                            <i data-feather="user-check" class="me-2 icon-primary"></i>
                            Gestión de Usuarios
                        </h5>
                        <p class="text-muted admin-card-desc">
                            Registra y administra los perfiles de los catedráticos del sistema, asignando
                            título académico, credenciales de acceso y datos de identidad.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-section-title mb-3">
                            <i data-feather="shield" class="me-2 icon-primary"></i>
                            Gestión de Administradores
                        </h5>
                        <p class="text-muted admin-card-desc">
                            Crea nuevas cuentas de administrador para el sistema. El nombre de usuario
                            se genera automáticamente con al menos 2 dígitos incluidos.
                        </p>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
    });
</script>
}
