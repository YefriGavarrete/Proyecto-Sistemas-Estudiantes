@model Proyecto_Evaluacion_Estudiantes.Models.ConfiguracionGradosViewModel
@{
    ViewData["Title"] = "Configuracion de Grados - EduPath AI";
    ViewData["ActiveMenu"] = "Academica";
    bool editando = Model.EditandoId.HasValue;
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="layers" class="icon-page-header me-2"></i>
                    Configuracion de Grados
                </h4>
                <h6>EduPath AI - Gestion de Grados Academicos (1 al 9)</h6>
            </div>
            <div class="page-btn d-flex gap-2">
                <a asp-controller="Administradores" asp-action="ConfiguracionAsignaturas"
                   class="btn-nav-est">
                    <i data-feather="book-open"></i> Asignaturas
                </a>
            </div>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-edupath-success" role="alert">
                <i data-feather="check-circle" class="me-2 icon-primary"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2 icon-danger"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (!editando)
        {
            <div class="alert d-flex align-items-center mb-4 alert-info-light">
                <i data-feather="info" class="me-3 flex-shrink-0 icon-info-18"></i>
                <small class="text-dark-navy">
                    Los grados <strong>1 al 9</strong> estan precargados. Solo puedes editar nombre, codigo,
                    nivel y estado. <strong>No se pueden crear ni eliminar</strong>.
                </small>
            </div>
        }

        @if (editando)
        {
            <div class="card mb-4">
                <div class="card-body">

                    <div class="d-flex align-items-center mb-4 pb-3 card-section-divider">
                        <div class="admin-stat-icon me-3 stat-icon-blue">
                            <i data-feather="edit-2" class="icon-stat-20w"></i>
                        </div>
                        <div>
                            <h5 class="card-section-title">Editar Grado</h5>
                            <small class="text-muted">
                                Modificando: <strong>@Model.FormNombre</strong>
                            </small>
                        </div>
                        <a asp-controller="Administradores" asp-action="ConfiguracionGrados"
                           class="btn-cancelar-form ms-auto">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar edicion
                        </a>
                    </div>

                    <form asp-controller="Administradores" asp-action="EditarGrado" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EditandoId" value="@Model.EditandoId" />

                        <div class="row g-3 mb-3">

                            <!-- Nombre -->
                            <div class="col-md-5">
                                <label class="form-label fw-semibold label-form">
                                    <i data-feather="layers" class="me-1 icon-primary"></i>
                                    Nombre del Grado
                                </label>
                                <input name="FormNombre" value="@Model.FormNombre"
                                       class="form-control"
                                       placeholder="Ej: Primer Grado"
                                       maxlength="100" required />
                                <span class="text-danger validation-msg">
                                    @Html.ValidationMessage("FormNombre")
                                </span>
                            </div>

                            <!-- Codigo -->
                            <div class="col-md-2">
                                <label class="form-label fw-semibold label-form">
                                    <i data-feather="hash" class="me-1 icon-primary"></i>
                                    Codigo
                                </label>
                                <input name="FormCodigo" value="@Model.FormCodigo"
                                       class="form-control"
                                       placeholder="Ej: 1"
                                       maxlength="10" required />
                                <span class="text-danger validation-msg">
                                    @Html.ValidationMessage("FormCodigo")
                                </span>
                            </div>

                            <!-- Nivel — select sin asp-for para evitar conflicto con tag helper -->
                            <div class="col-md-3">
                                <label class="form-label fw-semibold label-form">
                                    <i data-feather="tag" class="me-1 icon-primary"></i>
                                    Nivel
                                </label>
                                <select name="FormNivel" class="form-select" required>
                                    <option value="Primaria"
                                            selected="@(Model.FormNivel == "Primaria" ? "selected" : null)">
                                        Primaria
                                    </option>
                                    <option value="TercerCiclo"
                                            selected="@(Model.FormNivel == "TercerCiclo" ? "selected" : null)">
                                        Tercer Ciclo
                                    </option>
                                </select>
                                <span class="text-danger validation-msg">
                                    @Html.ValidationMessage("FormNivel")
                                </span>
                            </div>

                            <!-- Activo: checkbox PRIMERO, hidden DESPUES -->
                            <div class="col-md-2 d-flex align-items-end pb-1">
                                <div class="form-check form-switch">
                                    <input type="checkbox" name="FormActivo" value="true"
                                           class="form-check-input" role="switch"
                                           id="chkGradoActivo"
                                           @(Model.FormActivo ? "checked" : "") />
                                    <input type="hidden" name="FormActivo" value="false" />
                                    <label class="form-check-label fw-semibold label-form"
                                           for="chkGradoActivo">
                                        Activo
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Descripcion -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="align-left" class="me-1 icon-primary"></i>
                                Descripcion <small class="text-muted fw-normal">(opcional)</small>
                            </label>
                            <input name="FormDescripcion" value="@Model.FormDescripcion"
                                   class="form-control"
                                   placeholder="Ej: Primer Grado de Educacion Primaria"
                                   maxlength="300" />
                        </div>

                        <!-- Botones -->
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-controller="Administradores" asp-action="ConfiguracionGrados"
                               class="btn-cancelar-form">
                                <i data-feather="x" class="icon-14sq"></i> Cancelar
                            </a>
                            <button type="submit" class="btn-cfg-guardar">
                                <i data-feather="save" class="icon-16sq"></i>
                                Actualizar Grado
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        }

        <!-- Tabla de Grados -->
        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-3 pb-2 card-section-divider">
                    <div class="admin-stat-icon me-3 stat-icon-blue">
                        <i data-feather="list" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">Grados del Sistema</h5>
                        <small class="text-muted">Total: @Model.Grados.Count grado(s)</small>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover" id="tbl-grados">
                        <thead>
                            <tr>
                                <th class="w-col-40">#</th>
                                <th>Nombre</th>
                                <th class="w-col-80">Codigo</th>
                                <th class="w-col-140">Nivel</th>
                                <th>Descripcion</th>
                                <th class="text-center w-col-90">Estado</th>
                                <th class="text-center w-col-80">Editar</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var g in Model.Grados)
                            {
                                <tr class="@(g.Id == Model.EditandoId ? "table-info" : "")">
                                    <td>
                                        <span class="orden-grado">@g.Orden</span>
                                    </td>
                                    <td>
                                        <strong class="text-dark-navy">@g.Nombre</strong>
                                    </td>
                                    <td>
                                        <span class="badge badge-gradient-blue-lg">
                                            @g.Codigo
                                        </span>
                                    </td>
                                    <td>
                                        @if (g.Nivel == "TercerCiclo" || g.Nivel == "Tercer Ciclo")
                                        {
                                            <span class="badge badge-purple">
                                                Tercer Ciclo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-green">
                                                Primaria
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <small class="text-muted">@(g.Descripcion ?? "-")</small>
                                    </td>
                                    <td class="text-center">
                                        @if (g.Activo)
                                        {
                                            <span class="badge badge-green">
                                                Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-inactive">
                                                Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Administradores"
                                           asp-action="ConfiguracionGrados"
                                           asp-route-editarId="@g.Id"
                                           class="btn btn-sm btn-action-edit-sm"
                                           title="Editar grado">
                                            <i data-feather="edit-2" class="icon-14sq"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
    });
</script>
}
