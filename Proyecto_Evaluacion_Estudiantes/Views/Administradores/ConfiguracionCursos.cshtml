@model Proyecto_Evaluacion_Estudiantes.Models.ConfiguracionCursosViewModel
@{
    ViewData["Title"] = "Configuración de Cursos — EduPath AI";
    ViewData["ActiveMenu"] = "Administrador";
    bool editando = Model.EditandoId.HasValue;
}

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="book-open" style="color:#00b4d8;" class="me-2"></i>
                    Configuración de Cursos
                </h4>
                <h6>EduPath AI — Gestión de Cursos del Sistema</h6>
            </div>
        </div>



        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-edupath-success" role="alert">
                <i data-feather="check-circle" class="me-2" style="color:#00b4d8;"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2" style="color:#e17055;"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- ── Formulario Agregar / Editar ──────────────────────── -->
        <div class="card mb-4">
            <div class="card-body">

                <div class="d-flex align-items-center mb-4 pb-3" style="border-bottom:2px solid #e2e8f0;">
                    <div class="admin-stat-icon me-3"
                         style="background:linear-gradient(135deg,#0096c7,#48cae4);box-shadow:0 4px 12px rgba(0,150,199,.3);">
                        <i data-feather="@(editando ? "edit-2" : "plus-circle")" style="color:#fff;width:20px;height:20px;"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;color:#1a2b4a;font-weight:700;">
                            @(editando ? "Editar Curso" : "Nuevo Curso")
                        </h5>
                        <small class="text-muted">
                            @(editando ? $"Modificando el curso con ID {Model.EditandoId}" : "Complete los datos para registrar un nuevo curso.")
                        </small>
                    </div>
                    @if (editando)
                    {
                        <a asp-controller="Administradores" asp-action="ConfiguracionCursos"
                           class="btn-cancelar-form ms-auto">
                            <i data-feather="x" style="width:14px;height:14px;"></i> Cancelar edición
                        </a>
                    }
                </div>

                <form asp-controller="Administradores"
                      asp-action="@(editando ? "EditarCurso" : "ConfiguracionCursos")"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EditandoId" value="@Model.EditandoId" />

                    <div class="row g-3 mb-3">

                        <!-- Nombre del Curso -->
                        <div class="col-md-5">
                            <label class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="book" class="me-1" style="color:#00b4d8;"></i>
                                Nombre del Curso
                            </label>
                            <input name="FormNombre" value="@Model.FormNombre"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: Matemáticas – 1° Primaria A"
                                   maxlength="200" required />
                            <span class="text-danger" style="font-size:12px;">
                                @Html.ValidationMessage("FormNombre")
                            </span>
                        </div>

                        <!-- Código -->
                        <div class="col-md-2">
                            <label class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="hash" class="me-1" style="color:#00b4d8;"></i>
                                Código
                            </label>
                            <input name="FormCodigo" value="@Model.FormCodigo"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: MAT-1A"
                                   maxlength="30" required style="text-transform:uppercase;" />
                            <span class="text-danger" style="font-size:12px;">
                                @Html.ValidationMessage("FormCodigo")
                            </span>
                        </div>

                        <!-- Período -->
                        <div class="col-md-2">
                            <label class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="calendar" class="me-1" style="color:#00b4d8;"></i>
                                Período
                            </label>
                            <input name="FormPeriodo" value="@Model.FormPeriodo"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: 2026-1"
                                   maxlength="20" required />
                            <span class="text-danger" style="font-size:12px;">
                                @Html.ValidationMessage("FormPeriodo")
                            </span>
                        </div>

                        <!-- Docente -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold" style="color:#1a2b4a;">
                                <i data-feather="user-check" class="me-1" style="color:#00b4d8;"></i>
                                Docente Asignado
                            </label>
                            <select name="FormDocenteId" class="form-control form-control-edupath" required>
                                <option value="0">— Seleccionar docente —</option>
                                @foreach (var d in Model.Docentes)
                                {
                                    <option value="@d.Id" selected="@(Model.FormDocenteId == d.Id)">
                                        @d.Titulo @d.NombreCompleto
                                    </option>
                                }
                            </select>
                            <span class="text-danger" style="font-size:12px;">
                                @Html.ValidationMessage("FormDocenteId")
                            </span>
                        </div>
                    </div>

                    <!-- Activo -->
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input type="hidden" name="FormActivo" value="false" />
                            <input type="checkbox" name="FormActivo" value="true"
                                   class="form-check-input" role="switch"
                                   id="chkActivo" @(Model.FormActivo ? "checked" : "") />
                            <label class="form-check-label fw-semibold" for="chkActivo" style="color:#1a2b4a;">
                                Curso activo en el sistema
                            </label>
                        </div>
                    </div>

                    <!-- Botones -->
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Administradores" asp-action="Index" class="btn-cancelar-form">
                            <i data-feather="x" style="width:14px;height:14px;"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-cfg-guardar">
                            <i data-feather="save" style="width:16px;height:16px;"></i>
                            @(editando ? "Actualizar Curso" : "Guardar Curso")
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <!-- ── Tabla de Cursos existentes ───────────────────────── -->
        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-3 pb-2" style="border-bottom:2px solid #e2e8f0;">
                    <div class="admin-stat-icon me-3"
                         style="background:linear-gradient(135deg,#0096c7,#48cae4);box-shadow:0 4px 12px rgba(0,150,199,.3);">
                        <i data-feather="list" style="color:#fff;width:20px;height:20px;"></i>
                    </div>
                    <div>
                        <h5 style="margin:0;color:#1a2b4a;font-weight:700;">Cursos Registrados</h5>
                        <small class="text-muted">Total: @Model.Cursos.Count curso(s)</small>
                    </div>
                </div>

                @if (!Model.Cursos.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i data-feather="inbox" style="width:48px;height:48px;opacity:.3;" class="mb-3 d-block mx-auto"></i>
                        <p>No hay cursos registrados aún.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover datatable" id="tbl-cursos">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Código</th>
                                    <th>Período</th>
                                    <th>Docente</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Cursos)
                                {
                                    <tr>
                                        <td>
                                            <strong style="color:#1a2b4a;">@c.Nombre</strong>
                                        </td>
                                        <td>
                                            <span class="badge"
                                                  style="background:linear-gradient(135deg,#0096c7,#48cae4);color:#fff;
                                                         font-size:11px;padding:4px 8px;border-radius:6px;">
                                                @c.Codigo
                                            </span>
                                        </td>
                                        <td>@c.Periodo</td>
                                        <td>
                                            @if (c.Docente != null)
                                            {
                                                <span>@c.Docente.Titulo @c.Docente.NombreCompleto</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Sin asignar</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (c.Activo)
                                            {
                                                <span class="badge text-bg-success" style="font-size:11px;">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary" style="font-size:11px;">Inactivo</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-2 justify-content-center">

                                                <!-- Editar -->
                                                <a asp-controller="Administradores"
                                                   asp-action="ConfiguracionCursos"
                                                   asp-route-editarId="@c.Id"
                                                   class="btn btn-sm"
                                                   style="background:linear-gradient(135deg,#0096c7,#48cae4);color:#fff;
                                                          border:none;border-radius:6px;padding:4px 10px;"
                                                   title="Editar">
                                                    <i data-feather="edit-2" style="width:14px;height:14px;"></i>
                                                </a>

                                                <!-- Eliminar -->
                                                <form asp-controller="Administradores"
                                                      asp-action="EliminarCurso"
                                                      method="post"
                                                      onsubmit="return confirmarEliminar('@c.Nombre.Replace("'","\\'")')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@c.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm"
                                                            style="background:linear-gradient(135deg,#e17055,#ff7675);color:#fff;
                                                                   border:none;border-radius:6px;padding:4px 10px;"
                                                            title="Eliminar">
                                                        <i data-feather="trash-2" style="width:14px;height:14px;"></i>
                                                    </button>
                                                </form>

                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();

        // Inicializar DataTable si hay filas
        if (document.getElementById('tbl-cursos') &&
            document.querySelectorAll('#tbl-cursos tbody tr').length > 0) {
            $('#tbl-cursos').DataTable({
                language: {
                    search: "Buscar:",
                    lengthMenu: "Mostrar _MENU_ registros",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ cursos",
                    paginate: { previous: "Anterior", next: "Siguiente" },
                    zeroRecords: "No se encontraron cursos."
                },
                order: [[0, 'asc']]
            });
        }

        // Convertir código a mayúsculas al escribir
        var inputCodigo = document.querySelector('input[name="FormCodigo"]');
        if (inputCodigo) {
            inputCodigo.addEventListener('input', function () {
                var pos = this.selectionStart;
                this.value = this.value.toUpperCase();
                this.setSelectionRange(pos, pos);
            });
        }
    });

    function confirmarEliminar(nombre) {
        return confirm('¿Está seguro de que desea eliminar el curso "' + nombre + '"?\n\nEsta acción no se puede deshacer.');
    }
</script>
}
