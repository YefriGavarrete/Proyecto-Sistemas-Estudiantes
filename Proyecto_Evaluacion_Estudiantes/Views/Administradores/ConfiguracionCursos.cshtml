@model Proyecto_Evaluacion_Estudiantes.Models.ConfiguracionCursosViewModel
@{
    ViewData["Title"] = "Configuración de Cursos — EduPath AI";
    ViewData["ActiveMenu"] = "Administrador";
    bool editando = Model.EditandoId.HasValue;
}

<div class="page-wrapper">
    <div class="content">
        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="book-open" class="icon-page-header me-2"></i>
                    Configuración de Cursos
                </h4>
                <h6>EduPath AI — Gestión de Cursos del Sistema</h6>
            </div>
        </div>



        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show alert-edupath-success" role="alert">
                <i data-feather="check-circle" class="me-2 icon-primary"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2 icon-danger"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- ── Formulario Agregar / Editar -->
        <div class="card mb-4">
            <div class="card-body">

                <div class="d-flex align-items-center mb-4 pb-3 card-section-divider">
                    <div class="admin-stat-icon me-3 stat-icon-blue">
                        <i data-feather="@(editando ? "edit-2" : "plus-circle")" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">
                            @(editando ? "Editar Curso" : "Nuevo Curso")
                        </h5>
                        <small class="text-muted">
                            @(editando ? $"Modificando el curso con ID {Model.EditandoId}" : "Complete los datos para registrar un nuevo curso.")
                        </small>
                    </div>
                    @if (editando)
                    {
                        <a asp-controller="Administradores" asp-action="ConfiguracionCursos"
                           class="btn-cancelar-form ms-auto">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar edición
                        </a>
                    }
                </div>

                <form asp-controller="Administradores"
                      asp-action="@(editando ? "EditarCurso" : "ConfiguracionCursos")"
                      method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="EditandoId" value="@Model.EditandoId" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-5">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="book" class="me-1 icon-primary"></i>
                                Nombre del Curso
                            </label>
                            <input name="FormNombre" value="@Model.FormNombre"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: Matemáticas – 1° Primaria A"
                                   maxlength="200" required />
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormNombre")
                            </span>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="hash" class="me-1 icon-primary"></i>
                                Código
                            </label>
                            <input name="FormCodigo" value="@Model.FormCodigo"
                                   class="form-control form-control-edupath input-uppercase"
                                   placeholder="Ej: MAT-1A"
                                   maxlength="30" required />
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormCodigo")
                            </span>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="calendar" class="me-1 icon-primary"></i>
                                Período
                            </label>
                            <input name="FormPeriodo" value="@Model.FormPeriodo"
                                   class="form-control form-control-edupath"
                                   placeholder="Ej: 2026-1"
                                   maxlength="20" required />
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormPeriodo")
                            </span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-semibold label-form">
                                <i data-feather="user-check" class="me-1 icon-primary"></i>
                                Docente Asignado
                            </label>
                            <select name="FormDocenteId" class="form-control form-control-edupath" required>
                                <option value="0">— Seleccionar docente —</option>
                                @foreach (var d in Model.Docentes)
                                {
                                    <option value="@d.Id" selected="@(Model.FormDocenteId == d.Id)">
                                        @d.Titulo @d.NombreCompleto
                                    </option>
                                }
                            </select>
                            <span class="text-danger validation-msg">
                                @Html.ValidationMessage("FormDocenteId")
                            </span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input type="checkbox" name="FormActivo" value="true"
                                   class="form-check-input" role="switch"
                                   id="chkActivo" @(Model.FormActivo ? "checked" : "") />
                            <input type="hidden" name="FormActivo" value="false" />
                            <label class="form-check-label fw-semibold label-form" for="chkActivo">
                                Curso activo en el sistema
                            </label>
                        </div>
                    </div>


                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Administradores" asp-action="Index" class="btn-cancelar-form">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-cfg-guardar">
                            <i data-feather="save" class="icon-16sq"></i>
                            @(editando ? "Actualizar Curso" : "Guardar Curso")
                        </button>
                    </div>

                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-3 pb-2 card-section-divider">
                    <div class="admin-stat-icon me-3 stat-icon-blue">
                        <i data-feather="list" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">Cursos Registrados</h5>
                        <small class="text-muted">Total: @Model.Cursos.Count curso(s)</small>
                    </div>
                </div>

                @if (!Model.Cursos.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i data-feather="inbox" class="icon-inbox-empty mb-3 d-block mx-auto"></i>
                        <p>No hay cursos registrados aún.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover" id="tbl-cursos">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Código</th>
                                    <th>Período</th>
                                    <th>Docente</th>
                                    <th class="text-center">Estado</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in Model.Cursos)
                                {
                                    <tr>
                                        <td>
                                            <strong class="text-dark-navy">@c.Nombre</strong>
                                        </td>
                                        <td>
                                            <span class="badge badge-gradient-blue">
                                                @c.Codigo
                                            </span>
                                        </td>
                                        <td>@c.Periodo</td>
                                        <td>
                                            @if (c.DocenteTutor != null)
                                            {
                                                <span>@c.DocenteTutor.Titulo @c.DocenteTutor.NombreCompleto</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic">Sin asignar</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (c.Activo)
                                            {
                                                <span class="badge text-bg-success badge-status-sm">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary badge-status-sm">Inactivo</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-2 justify-content-center">

                                                <!-- Editar -->
                                                <a asp-controller="Administradores"
                                                   asp-action="ConfiguracionCursos"
                                                   asp-route-editarId="@c.Id"
                                                   class="btn btn-sm btn-action-edit"
                                                   title="Editar">
                                                    <i data-feather="edit-2" class="icon-14sq"></i>
                                                </a>

                                                <!-- Eliminar -->
                                                <form asp-controller="Administradores"
                                                      asp-action="EliminarCurso"
                                                      method="post"
                                                      onsubmit="return confirmarEliminar('@c.Nombre.Replace("'","\\'")')">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@c.Id" />
                                                    <button type="submit"
                                                            class="btn btn-sm btn-action-delete"
                                                            title="Eliminar">
                                                        <i data-feather="trash-2" class="icon-14sq"></i>
                                                    </button>
                                                </form>

                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();

        // Inicializar DataTable solo si el template no lo hizo ya
        var tblCursos = document.getElementById('tbl-cursos');
        if (tblCursos && typeof $.fn.DataTable !== 'undefined' && !$.fn.DataTable.isDataTable('#tbl-cursos')) {
            $('#tbl-cursos').DataTable({
                language: {
                    search: "Buscar:",
                    lengthMenu: "Mostrar _MENU_ registros",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ cursos",
                    paginate: { previous: "Anterior", next: "Siguiente" },
                    zeroRecords: "No se encontraron cursos."
                },
                order: [[0, 'asc']]
            });
        }

        // Convertir código a mayúsculas al escribir
        var inputCodigo = document.querySelector('input[name="FormCodigo"]');
        if (inputCodigo) {
            inputCodigo.addEventListener('input', function () {
                var pos = this.selectionStart;
                this.value = this.value.toUpperCase();
                this.setSelectionRange(pos, pos);
            });
        }
    });

    function confirmarEliminar(nombre) {
        return confirm('¿Está seguro de que desea eliminar el curso "' + nombre + '"?\n\nEsta acción no se puede deshacer.');
    }
</script>
}
