@model Proyecto_Evaluacion_Estudiantes.Models.ReporteGeneralViewModel
@{
    ViewData["Title"] = "Reporte Académico General — EduPath AI";
    ViewData["ActiveMenu"] = "Reportes";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="bar-chart-2" class="icon-page-header me-2"></i>
                    Reporte Académico General
                </h4>
                <h6>EduPath AI — Resumen del desempeño del grupo</h6>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card text-center py-3">
                    <div class="card-body py-2">
                        <div class="stat-number-primary">@Model.TotalEstudiantes</div>
                        <div class="stat-label">Total Estudiantes</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card text-center py-3">
                    <div class="card-body py-2">
                        <div class="stat-number-success">@Model.Aprobados</div>
                        <div class="stat-label">Aprobados</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card text-center py-3">
                    <div class="card-body py-2">
                        <div class="stat-number-danger">@Model.Reprobados</div>
                        <div class="stat-label">Reprobados</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card text-center py-3">
                    <div class="card-body py-2">
                        <div class="stat-number-dark">@Model.PromedioGeneral.ToString("F1")</div>
                        <div class="stat-label">Promedio General</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-section-title mb-3" style="margin-bottom:16px!important;">
                            <i data-feather="trending-up" class="icon-16-primary-sm me-1"></i>
                            Promedio por Parcial
                        </h6>
                        @{
                            var parciales = new[]
                            {
                                ("Parcial 1", Model.PromedioParcial1),
                                ("Parcial 2", Model.PromedioParcial2),
                                ("Parcial 3", Model.PromedioParcial3),
                                ("Parcial 4", Model.PromedioParcial4),
                            };
                        }
                        @foreach (var (nombre, prom) in parciales)
                        {
                            decimal pct = prom > 0 ? prom : 0;
                            string color = pct >= 60 ? "#00b894" : (pct > 0 ? "#e17055" : "#cbd5e0");
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="parcial-label-name">@nombre</span>
                                    <span style="font-size:13px;font-weight:700;color:@color;">
                                        @(pct > 0 ? pct.ToString("F1") : "Sin datos")
                                    </span>
                                </div>
                                <div class="progress-bar-bg">
                                    <div style="height:100%;width:@(pct)%;background:@color;border-radius:4px;transition:width .4s;"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-section-title mb-3" style="margin-bottom:16px!important;">
                            <i data-feather="pie-chart" class="icon-16-primary-sm me-1"></i>
                            Distribución de Promedios
                        </h6>
                        @{
                            var rangos = new[]
                            {
                                ("0 – 59 (Reprobado)", Model.Rango0_59,   "#e17055"),
                                ("60 – 69",            Model.Rango60_69,  "#fdcb6e"),
                                ("70 – 79",            Model.Rango70_79,  "#74b9ff"),
                                ("80 – 89",            Model.Rango80_89,  "#00b894"),
                                ("90 – 100",           Model.Rango90_100, "#0096c7"),
                            };
                            int conProm = Model.TotalEstudiantes - Model.SinNotas;
                        }
                        @foreach (var (label, count, color) in rangos)
                        {
                            decimal pct = conProm > 0 ? Math.Round(count * 100m / conProm, 1) : 0;
                            <div class="mb-2 d-flex align-items-center gap-2">
                                <div style="width:12px;height:12px;border-radius:3px;background:@color;flex-shrink:0;"></div>
                                <span class="dist-label">@label</span>
                                <span style="font-size:12px;font-weight:700;color:@color;min-width:32px;text-align:right;">@count</span>
                                <div class="dist-bar-bg">
                                    <div style="height:100%;width:@(pct)%;background:@color;border-radius:4px;"></div>
                                </div>
                                <span class="dist-pct">@pct%</span>
                            </div>
                        }
                        @if (Model.SinNotas > 0)
                        {
                            <div class="mt-2 d-flex align-items-center gap-2">
                                <div style="width:12px;height:12px;border-radius:3px;background:#cbd5e0;flex-shrink:0;"></div>
                                <span class="dist-label">Sin notas</span>
                                <span class="dist-pct fw-bold text-muted">@Model.SinNotas</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h6 class="card-section-title mb-3" style="margin-bottom:16px!important;">
                    <i data-feather="users" class="icon-16-primary-sm me-1"></i>
                    Detalle de Estudiantes
                </h6>
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaReporte">
                        <thead class="thead-light-blue">
                            <tr>
                                <th>Código</th>
                                <th>Estudiante</th>
                                <th class="w-col-80">Sección</th>
                                <th class="w-col-80">P1</th>
                                <th class="w-col-80">P2</th>
                                <th class="w-col-80">P3</th>
                                <th class="w-col-80">P4</th>
                                <th class="w-col-90">Promedio</th>
                                <th class="w-col-100">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Estudiantes.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i data-feather="inbox" class="me-2"></i>
                                        No hay estudiantes registrados.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var est in Model.Estudiantes)
                                {
                                    <tr>
                                        <td><small class="text-muted">@(est.Codigo.Length > 0 ? est.Codigo : $"#{est.Id}")</small></td>
                                        <td>
                                            <strong>@est.NombreCompleto</strong>
                                            <br><small class="text-muted">@est.Correo</small>
                                        </td>
                                        <td><small>@(est.Seccion ?? "—")</small></td>
                                        <td>
                                            @if (est.Nota1.HasValue)
                                            { <span class="badge @(est.Nota1 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota1.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota2.HasValue)
                                            { <span class="badge @(est.Nota2 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota2.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota3.HasValue)
                                            { <span class="badge @(est.Nota3 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota3.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota4.HasValue)
                                            { <span class="badge @(est.Nota4 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota4.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Promedio.HasValue)
                                            {
                                                <strong style="color:@(est.Promedio >= 60 ? "#00b894" : "#e17055")">
                                                    @est.Promedio.Value.ToString("F2")
                                                </strong>
                                            }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            <span class="badges @est.EstadoBadge">@(est.Estado ?? "Sin Notas")</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
        if ($.fn.DataTable) {
            $('#tablaReporte').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                paging: false,
                lengthChange: false,
                order: [[7, 'asc']]
            });
        }
    });
</script>
}
