@model Proyecto_Evaluacion_Estudiantes.Models.ReporteRiesgoViewModel
@{
    ViewData["Title"] = "Estudiantes en Riesgo — EduPath AI";
    ViewData["ActiveMenu"] = "Reportes";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="alert-triangle" class="text-danger me-2"></i>
                    Estudiantes en Riesgo
                </h4>
                <h6>EduPath AI — Promedio menor a 65 o marcados por IA</h6>
            </div>
            <div class="page-btn d-flex gap-2 flex-wrap">
                <a asp-controller="Estudiantes" asp-action="Prediccion" class="btn-nav-est">
                    <i data-feather="cpu"></i> Predicción IA
                </a>
            </div>
        </div>

        @if (!Model.Estudiantes.Any())
        {
            <div class="alert alert-success d-flex align-items-center alert-rounded">
                <i data-feather="check-circle" class="icon-24-success me-3"></i>
                <div>
                    <strong>¡Sin estudiantes en riesgo!</strong><br>
                    <small>Todos tus estudiantes tienen un promedio mayor a 65.</small>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning d-flex align-items-center mb-4 alert-warning-edupath">
                <i data-feather="alert-triangle" class="icon-20-danger me-3"></i>
                <small class="text-dark-navy">
                    Se encontraron <strong>@Model.Estudiantes.Count estudiante(s)</strong> en riesgo.
                    Se recomienda intervención académica a la brevedad.
                </small>
            </div>

            <div class="card">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover" id="tablaRiesgo">
                            <thead class="thead-light-rose">
                                <tr>
                                    <th>Código</th>
                                    <th>Estudiante</th>
                                    <th class="w-col-80">Sección</th>
                                    <th class="w-col-80">P1</th>
                                    <th class="w-col-80">P2</th>
                                    <th class="w-col-80">P3</th>
                                    <th class="w-col-80">P4</th>
                                    <th class="w-col-90">Promedio</th>
                                    <th class="w-col-110">Situación</th>
                                    <th class="w-col-90">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var est in Model.Estudiantes)
                                {
                                    bool critico = est.Promedio.HasValue && est.Promedio.Value < 50;
                                    <tr style="@(critico ? "background:#fff5f5;" : "")">
                                        <td><small class="text-muted">@(est.Codigo.Length > 0 ? est.Codigo : $"#{est.Id}")</small></td>
                                        <td>
                                            <strong>@est.NombreCompleto</strong>
                                            <br><small class="text-muted">@est.Correo</small>
                                        </td>
                                        <td><small>@(est.Seccion ?? "—")</small></td>
                                        <td>
                                            @if (est.Nota1.HasValue)
                                            { <span class="badge @(est.Nota1 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota1.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota2.HasValue)
                                            { <span class="badge @(est.Nota2 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota2.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota3.HasValue)
                                            { <span class="badge @(est.Nota3 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota3.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota4.HasValue)
                                            { <span class="badge @(est.Nota4 >= 60 ? "bg-success" : "bg-danger") badge-nota">@est.Nota4.Value.ToString("F1")</span> }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Promedio.HasValue)
                                            {
                                                <strong class="promedio-riesgo">@est.Promedio.Value.ToString("F2")</strong>
                                            }
                                            else { <span class="text-muted">Sin datos</span> }
                                        </td>
                                        <td>
                                            @if (critico)
                                            {
                                                <span class="badge badge-critico">
                                                    <i data-feather="alert-circle" class="icon-11"></i> Crítico
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-riesgo">
                                                    <i data-feather="alert-triangle" class="icon-11"></i> En riesgo
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Estudiantes" asp-action="Editar"
                                               asp-route-id="@est.Id"
                                               class="btn btn-sm btn-action-mini">
                                                <i data-feather="edit-2" class="icon-11"></i> Editar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
        if ($.fn.DataTable && document.getElementById('tablaRiesgo')) {
            $('#tablaRiesgo').DataTable({
                language: { url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json' },
                pageLength: 25,
                order: [[7, 'asc']]
            });
        }
    });
</script>
}
