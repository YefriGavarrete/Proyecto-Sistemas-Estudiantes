@model Proyecto_Evaluacion_Estudiantes.Models.SubirNotasSeleccionViewModel
@{
    ViewData["Title"]      = "Subir Notas — EduPath AI";
    ViewData["ActiveMenu"] = "Notas";
}

@section Styles {
    <link rel="stylesheet" href="~/css/SubirNotas.css" />
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="upload" class="subirnotas-icon-header me-2"></i>
                    Subir Notas
                </h4>
                <h6>EduPath AI — Selecciona el curso y el parcial para ingresar calificaciones</h6>
            </div>
            <div class="page-btn d-flex gap-2 flex-wrap">
                <a asp-controller="Estudiantes" asp-action="Index" class="btn-nav-est">
                    <i data-feather="list"></i> Lista de Estudiantes
                </a>
                <a asp-controller="Estudiantes" asp-action="Registro" class="btn-nav-est">
                    <i data-feather="user-plus"></i> Registrar Estudiante
                </a>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-8 col-md-10">
                <div class="card card-subirnotas">
                    <div class="card-body p-4">

                        <div class="d-flex align-items-center mb-4 pb-3 subirnotas-card-header">
                            <div class="admin-stat-icon subirnotas-stat-icon me-3">
                                <i data-feather="layers" class="subirnotas-icon-layers"></i>
                            </div>
                            <div>
                                <h5 class="mb-0 subirnotas-titulo">
                                    Seleccionar Curso y Parcial
                                </h5>
                                <small class="text-muted">
                                    Solo se muestran los cursos donde tienes asignación activa.
                                </small>
                            </div>
                        </div>

                        <form asp-action="SubirNotas" asp-controller="Estudiantes"
                              method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div class="mb-4">
                                <label asp-for="CursoId" class="form-label fw-semibold label-dark-navy">
                                    <i data-feather="book-open" class="icon-15-primary"></i>
                                    Curso
                                </label>
                                <select asp-for="CursoId"
                                        class="form-select form-control-edupath"
                                        id="selectCurso">
                                    <option value="">— Selecciona el grado y sección —</option>
                                    @foreach (var item in Model.CursosDisponibles)
                                    {
                                        <option value="@item.Value"
                                                selected="@(item.Selected ? "selected" : null)">
                                            @item.Text
                                        </option>
                                    }
                                </select>
                                <span asp-validation-for="CursoId"
                                      class="text-danger small"></span>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Parcial" class="form-label fw-semibold label-dark-navy">
                                    <i data-feather="bookmark" class="icon-15-primary"></i>
                                    Parcial
                                </label>

                                <!-- Opciones de parcial como tarjetas clicables -->
                                <div class="d-flex gap-2 flex-wrap mt-1" id="parcialesGroup">
                                    @foreach (var item in Model.ParcialesItems)
                                    {
                                        bool seleccionado = Model.Parcial.HasValue
                                                         && Model.Parcial.Value.ToString() == item.Value;
                                        <label class="parcial-card @(seleccionado ? "parcial-card-activa" : "")"
                                               for="parcial_@item.Value">
                                            <input type="radio"
                                                   id="parcial_@item.Value"
                                                   name="Parcial"
                                                   value="@item.Value"
                                                   class="d-none parcial-radio"
                                                   @(seleccionado ? "checked" : "") />
                                            <i data-feather="edit-3" class="icon-14"></i>
                                            @item.Text
                                        </label>
                                    }
                                </div>
                                <span asp-validation-for="Parcial"
                                      class="text-danger small d-block mt-1"></span>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-subirnotas-submit">
                                    <i data-feather="arrow-right" class="icon-16 me-2"></i>
                                    Ver Grilla de Calificaciones
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="alert alert-info d-flex align-items-start py-3 mt-2 alert-info-subirnotas">
                    <i data-feather="info" class="icon-16-primary me-3 mt-1 flex-shrink-0"></i>
                    <div class="alert-info-texto">
                        <strong>¿Cómo funciona Subir Notas?</strong><br>
                        Al seleccionar el curso y parcial verás una grilla con una fila por
                        estudiante y una columna por cada asignatura que tienes asignada en ese curso.
                        Ingresa las notas (0–100) y guarda todo de una sola vez.
                        El sistema calculará automáticamente el promedio del parcial y actualizará
                        el promedio general y el estado de cada estudiante.
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.feather) feather.replace();

    // Efecto visual en tarjetas de parcial
    document.querySelectorAll('.parcial-radio').forEach(function(radio) {
        radio.addEventListener('change', function () {
            document.querySelectorAll('.parcial-card').forEach(function(lbl) {
                lbl.classList.remove('parcial-card-activa');
            });
            if (this.checked) {
                this.parentElement.classList.add('parcial-card-activa');
            }
        });
    });
});
</script>
}
