@model Proyecto_Evaluacion_Estudiantes.Models.Estudiante
@{
    ViewData["Title"] = "Editar Estudiante — EduPath AI";
    ViewData["ActiveMenu"] = "Informacion";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="edit-2" class="icon-page-header me-2"></i>
                    Editar Estudiante
                </h4>
                <h6>EduPath AI — Modificar datos de @Model.NombreCompleto</h6>
            </div>
            <div class="page-btn d-flex gap-2 flex-wrap">
                <a asp-controller="Estudiantes" asp-action="Registro" class="btn-nav-est">
                    <i data-feather="user-plus"></i> Registrar Estudiante
                </a>
                <a asp-controller="Estudiantes" asp-action="Index" class="btn-nav-est">
                    <i data-feather="list"></i> Lista de Estudiantes
                </a>
                <a asp-controller="Estudiantes" asp-action="RegistroNotas" class="btn-nav-est">
                    <i data-feather="edit-3"></i> Subir Notas
                </a>
            </div>
        </div>

        <div class="card">
            <div class="card-body">

                <div class="d-flex align-items-center mb-4 pb-3 card-section-divider">
                    <div class="admin-stat-icon stat-icon-blue me-3">
                        <i data-feather="user" class="icon-stat-20w"></i>
                    </div>
                    <div>
                        <h5 class="card-section-title">@Model.NombreCompleto</h5>
                        <small class="text-muted">Código: @(Model.Codigo.Length > 0 ? Model.Codigo : $"#{Model.Id}") · @Model.Edad años</small>
                    </div>
                </div>

                <form asp-controller="Estudiantes" asp-action="Editar" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="CursoId" type="hidden" />

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold label-form">
                                <i data-feather="user" class="icon-primary me-1"></i>
                                @Html.DisplayNameFor(m => m.Nombre) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Nombre" class="form-control form-control-edupath" maxlength="100" />
                            <span asp-validation-for="Nombre" class="text-danger validation-msg"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Apellido" class="form-label fw-semibold label-form">
                                <i data-feather="user" class="icon-primary me-1"></i>
                                @Html.DisplayNameFor(m => m.Apellido) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Apellido" class="form-control form-control-edupath" maxlength="100" />
                            <span asp-validation-for="Apellido" class="text-danger validation-msg"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="FechaNacimiento" class="form-label fw-semibold label-form">
                                <i data-feather="calendar" class="icon-primary me-1"></i>
                                @Html.DisplayNameFor(m => m.FechaNacimiento) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="FechaNacimiento" type="date"
                                   class="form-control form-control-edupath"
                                   id="fechaNac" oninput="calcularEdad()" />
                            <span asp-validation-for="FechaNacimiento" class="text-danger validation-msg"></span>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label fw-semibold label-form">Edad</label>
                            <div class="form-control form-control-edupath edad-display">
                                <span id="edadCalculada" class="edad-value">@Model.Edad</span> años
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Genero" class="form-label fw-semibold label-form">
                                @Html.DisplayNameFor(m => m.Genero)
                            </label>
                            <select asp-for="Genero" class="form-select form-control-edupath">
                                <option value="">— Seleccionar —</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="Seccion" class="form-label fw-semibold label-form">
                                @Html.DisplayNameFor(m => m.Seccion)
                            </label>
                            <select asp-for="Seccion" class="form-select form-control-edupath">
                                <option value="">— Sin sección —</option>
                                <option value="Sección A">Sección A</option>
                                <option value="Sección B">Sección B</option>
                                <option value="Sección C">Sección C</option>
                                <option value="Sección D">Sección D</option>
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="Identidad" class="form-label fw-semibold label-form">
                                @Html.DisplayNameFor(m => m.Identidad)
                            </label>
                            <input asp-for="Identidad" class="form-control form-control-edupath" maxlength="20" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Correo" class="form-label fw-semibold label-form">
                                @Html.DisplayNameFor(m => m.Correo) <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Correo" type="email" class="form-control form-control-edupath" maxlength="150" />
                            <span asp-validation-for="Correo" class="text-danger validation-msg"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Telefono" class="form-label fw-semibold label-form">
                                @Html.DisplayNameFor(m => m.Telefono)
                            </label>
                            <input asp-for="Telefono" class="form-control form-control-edupath" maxlength="20" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observaciones" class="form-label fw-semibold label-form">
                            @Html.DisplayNameFor(m => m.Observaciones)
                        </label>
                        <textarea asp-for="Observaciones" class="form-control form-control-edupath"
                                  rows="2" maxlength="500"></textarea>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="Activo" class="form-check-label fw-semibold label-form">
                                Estudiante activo
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-controller="Estudiantes" asp-action="Index" class="btn-cancelar-form">
                            <i data-feather="x" class="icon-14sq"></i> Cancelar
                        </a>
                        <button type="submit" class="btn-cfg-guardar">
                            <i data-feather="save" class="icon-16sq me-2"></i>
                            Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
<script>
    function calcularEdad() {
        const f = new Date(document.getElementById('fechaNac').value);
        const hoy = new Date();
        let edad = hoy.getFullYear() - f.getFullYear();
        if (hoy.getMonth() - f.getMonth() < 0 ||
            (hoy.getMonth() - f.getMonth() === 0 && hoy.getDate() < f.getDate())) edad--;
        const span = document.getElementById('edadCalculada');
        span.textContent = isNaN(edad) || edad < 0 ? '?' : edad;
        span.style.color = edad >= 15 ? '#0096c7' : '#e17055';
    }
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
    });
</script>
}
