@model Proyecto_Evaluacion_Estudiantes.Models.SubirNotasGrillaViewModel
@{
    ViewData["Title"]      = $"Notas — {Model.ParcialNombre} — {Model.CursoNombre} — EduPath AI";
    ViewData["ActiveMenu"] = "Notas";
    int idx = 0;  // índice global para el binding de la lista de entradas
}

@section Styles {
    <link rel="stylesheet" href="~/css/SubirNotasGrilla.css" />
}

<div class="page-wrapper">
    <div class="content">


        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="grid" class="grilla-icon-header me-2"></i>
                    Calificaciones — @Model.ParcialNombre
                </h4>
                <h6>@Model.CursoNombre</h6>
            </div>
            <div class="page-btn d-flex gap-2 flex-wrap">
                <a asp-controller="Estudiantes" asp-action="SubirNotas" class="btn-nav-est">
                    <i data-feather="arrow-left"></i> Cambiar selección
                </a>
                <a asp-controller="Estudiantes" asp-action="Index" class="btn-nav-est">
                    <i data-feather="list"></i> Lista de Estudiantes
                </a>
            </div>
        </div>

        @if (TempData["MensajeExito"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i data-feather="check-circle" class="me-2"></i>
                @TempData["MensajeExito"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i data-feather="alert-circle" class="me-2"></i>
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- ── Tarjeta de estado ── -->
        <div class="card mb-3 card-estado-parcial">
            <div class="card-body py-3">
                <div class="d-flex align-items-center flex-wrap gap-4">


                    <div class="d-flex align-items-center gap-2">
                        <i data-feather="bookmark" class="icon-16-primary"></i>
                        <strong class="text-dark-navy">Parcial:</strong>
                    </div>
                    <div class="d-flex gap-2 flex-wrap">
                        @for (int p = 1; p <= 4; p++)
                        {
                            bool activo = Model.Parcial == p;
                            <a asp-controller="Estudiantes" asp-action="SubirNotasGrilla"
                               asp-route-cursoId="@Model.CursoId"
                               asp-route-parcial="@p"
                               class="btn-parcial @(activo ? "btn-parcial-activo" : "")">
                                <i data-feather="edit-3" class="icon-13"></i>
                                Parcial @p
                            </a>
                        }
                    </div>

                    <!-- Estadísticas -->
                    <div class="ms-auto d-flex gap-4 stats-grilla">
                        <span>
                            <i data-feather="users" class="icon-14-primary"></i>
                            <strong>@Model.Filas.Count</strong>
                            <span class="text-muted">estudiantes</span>
                        </span>
                        <span>
                            <i data-feather="book" class="icon-14-muted"></i>
                            <strong>@Model.Asignaturas.Count</strong>
                            <span class="text-muted">asignaturas</span>
                        </span>
                        <span class="stats-aprobado">
                            <i data-feather="check-circle" class="icon-14"></i>
                            @Model.CeldasConNota subidas
                        </span>
                        <span class="stats-pendiente">
                            <i data-feather="clock" class="icon-14"></i>
                            @Model.CeldasSinNota pendientes
                        </span>
                    </div>
                </div>
            </div>
        </div>


        <div class="alert alert-info d-flex align-items-center py-2 mb-3 alert-instruccion-grilla">
            <i data-feather="info" class="icon-16-primary me-2"></i>
            <small class="text-dark-navy">
                Solo los estudiantes <strong>sin nota</strong> tienen celdas editables.
                Para modificar una nota ya ingresada, usa el botón
                <i data-feather="edit-2" style="width:12px;height:12px;"></i>
                <strong>Editar</strong> en la columna de acciones de ese estudiante.
            </small>
        </div>


        @if (!Model.Filas.Any())
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <i data-feather="inbox" class="icon-empty-state mb-3"></i>
                    <p class="text-muted mb-1">No hay estudiantes activos en este curso.</p>
                    <a asp-controller="Estudiantes" asp-action="Registro" class="btn btn-sm btn-outline-primary">
                        Registrar estudiante
                    </a>
                </div>
            </div>
        }
        else
        {
            <form asp-action="GuardarGrilla" asp-controller="Estudiantes"
                  method="post" id="formGrilla">
                @Html.AntiForgeryToken()

                <!-- Parámetros de contexto -->
                <input type="hidden" name="cursoId" value="@Model.CursoId" />
                <input type="hidden" name="parcial"  value="@Model.Parcial"  />

                <div class="card mb-3">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover mb-0" id="tablaGrilla"
                                   style="min-width:@(200 + Model.Asignaturas.Count * 130 + 100)px;">
                                <thead class="thead-grilla">
                                    <tr>
                                        <th class="th-col-estudiante">
                                            <i data-feather="user" class="icon-14-primary"></i>
                                            Estudiante
                                        </th>

                                        <!-- Una columna por asignatura -->
                                        @foreach (var asig in Model.Asignaturas)
                                        {
                                            <th class="text-center th-col-asignatura" title="@asig.Nombre">
                                                <div class="asig-codigo">@asig.Codigo</div>
                                                <div class="asig-nombre">@asig.Nombre</div>
                                            </th>
                                        }

 
                                        <th class="text-center" style="width:90px;min-width:90px;">
                                            <i data-feather="settings" class="icon-14-primary"></i>
                                            Acciones
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fila in Model.Filas)
                                    {
                                        // Determinar si el estudiante tiene alguna nota en el parcial


                                        bool filaConNota = fila.NotasPorAsignatura.Values.Any(n => n.HasValue);
                                        string filaId = $"fila-{fila.EstudianteId}";

                                        <tr class="fila-grilla" id="@filaId"
                                            data-tiene-nota="@(filaConNota ? "true" : "false")">

        
                                            <td class="td-col-estudiante">
                                                <div class="estudiante-nombre">@fila.NombreCompleto</div>
                                                <small class="text-muted estudiante-codigo">
                                                    @(string.IsNullOrEmpty(fila.Codigo) ? $"#{fila.EstudianteId}" : fila.Codigo)
                                                </small>
                                            </td>

                                            @foreach (var asig in Model.Asignaturas)
                                            {
                                                decimal? notaActual = fila.NotasPorAsignatura.TryGetValue(asig.Id, out var n) ? n : null;
                                                bool tieneNota = notaActual.HasValue;
                                                string colorBorde = tieneNota
                                                    ? (notaActual >= 60 ? "2px solid #c3f5e4" : "2px solid #fde8e6")
                                                    : "1px solid #dee2e6";
                                                string colorFondo = tieneNota
                                                    ? (notaActual >= 60 ? "#f6fffe" : "#fff8f7")
                                                    : "transparent";
                                                string colorTexto = tieneNota
                                                    ? (notaActual >= 60 ? "#00b894" : "#e17055")
                                                    : "#495057";

                                                <td class="celda-nota text-center p-1"
                                                    style="border:@colorBorde;background:@colorFondo;">


                                                    <input type="hidden"
                                                           name="entradas[@idx].EstudianteId"
                                                           value="@fila.EstudianteId" />
                                                    <input type="hidden"
                                                           name="entradas[@idx].AsignaturaId"
                                                           value="@asig.Id" />

                                                    @if (filaConNota)
                                                    {

                                                        <span class="nota-display fw-semibold"
                                                              style="color:@colorTexto;font-size:13px;">
                                                            @(tieneNota ? notaActual!.Value.ToString("F2") : "—")
                                                        </span>
                                                        <input type="number"
                                                               name="entradas[@idx].Nota"
                                                               class="form-control form-control-sm input-nota-grilla text-center input-nota-bloqueada"
                                                               min="0" max="100" step="0.01"
                                                               value="@(tieneNota ? notaActual!.Value.ToString("F2") : "")"
                                                               readonly
                                                               style="display:none;font-weight:600;color:@colorTexto;" />
                                                    }
                                                    else
                                                    {
                                                        // ESTUDIANTE SIN NOTAS: input editable directamente
                                                        <input type="number"
                                                               name="entradas[@idx].Nota"
                                                               class="form-control form-control-sm input-nota-grilla text-center"
                                                               min="0" max="100" step="0.01"
                                                               value=""
                                                               placeholder="—"
                                                               style="font-weight:400;color:#495057;" />
                                                    }
                                                </td>
                                                idx++;
                                            }


                                            <td class="text-center align-middle">
                                                @if (filaConNota)
                                                {
                                                    <button type="button"
                                                            class="btn btn-sm btn-action-edit-sm btn-editar-fila"
                                                            data-fila="@filaId"
                                                            title="Editar notas de este estudiante">
                                                        <i data-feather="edit-2" class="icon-14sq"></i>
                                                    </button>
                                                    <button type="button"
                                                            class="btn btn-sm btn-cancelar-form btn-cancelar-fila"
                                                            data-fila="@filaId"
                                                            title="Cancelar edición"
                                                            style="display:none;">
                                                        <i data-feather="x" class="icon-14sq"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted" style="font-size:11px;">Sin notas</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>


                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
                    <div>
                        <small class="text-muted">
                            <i data-feather="alert-circle" class="icon-13"></i>
                            Las celdas vacías no se modificarán. Solo se guardan los campos habilitados.
                        </small>
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Estudiantes" asp-action="SubirNotas"
                           class="btn btn-outline-secondary btn-cancelar-grilla">
                            <i data-feather="x" class="icon-14 me-1"></i>
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary btn-guardar-grilla">
                            <i data-feather="save" class="icon-14 me-1"></i>
                            Guardar Notas
                        </button>
                    </div>
                </div>

            </form>
        }

    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.feather) feather.replace();

    // Editar fila
    document.querySelectorAll('.btn-editar-fila').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var filaId  = this.dataset.fila;
            var fila    = document.getElementById(filaId);

            // Mostrar inputs y ocultar spans de esa fila
            fila.querySelectorAll('.nota-display').forEach(function (span) {
                span.style.display = 'none';
            });
            fila.querySelectorAll('.input-nota-bloqueada').forEach(function (input) {
                input.style.display = '';
                input.removeAttribute('readonly');
                input.classList.remove('input-nota-bloqueada');
                input.classList.add('input-nota-grilla-editando');
                actualizarColorInput(input);
            });


            btn.style.display = 'none';
            var cancelBtn = fila.querySelector('.btn-cancelar-fila');
            if (cancelBtn) cancelBtn.style.display = '';

            feather.replace();
        });
    });


    document.querySelectorAll('.btn-cancelar-fila').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var filaId = this.dataset.fila;
            var fila   = document.getElementById(filaId);

            // Restaurar spans y ocultar inputs
            fila.querySelectorAll('.input-nota-grilla-editando').forEach(function (input) {
                input.setAttribute('readonly', '');
                input.classList.add('input-nota-bloqueada');
                input.classList.remove('input-nota-grilla-editando');
                input.style.display = 'none';
            });
            fila.querySelectorAll('.nota-display').forEach(function (span) {
                span.style.display = '';
            });


            btn.style.display = 'none';
            var editBtn = fila.querySelector('.btn-editar-fila');
            if (editBtn) editBtn.style.display = '';

            feather.replace();
        });
    });

    // ── Colores dinámicos al escribir ──
    document.querySelectorAll('.input-nota-grilla').forEach(function (input) {
        input.addEventListener('input', function () { actualizarColorInput(this); });
        input.addEventListener('focus', function () {
            this.select();
            this.style.outline = '2px solid #0096c7';
        });
        input.addEventListener('blur', function () {
            this.style.outline = '';
            actualizarColorInput(this);
        });
    });


    document.getElementById('tablaGrilla')?.addEventListener('input', function (e) {
        if (e.target.classList.contains('input-nota-grilla-editando')) {
            actualizarColorInput(e.target);
        }
    });

    function actualizarColorInput(input) {
        var td  = input.closest('td');
        var val = parseFloat(input.value);
        if (isNaN(val) || input.value.trim() === '') {
            input.style.color      = '#495057';
            input.style.fontWeight = '400';
            td.style.background    = 'transparent';
            td.style.border        = '1px solid #dee2e6';
        } else if (val >= 60) {
            input.style.color      = '#00b894';
            input.style.fontWeight = '600';
            td.style.background    = '#f6fffe';
            td.style.border        = '2px solid #c3f5e4';
        } else {
            input.style.color      = '#e17055';
            input.style.fontWeight = '600';
            td.style.background    = '#fff8f7';
            td.style.border        = '2px solid #fde8e6';
        }
    }


    document.querySelector('.btn-guardar-grilla')?.addEventListener('click', function (e) {
        var totalCeldas = @Model.TotalCeldas;
        if (totalCeldas > 30) {
            if (!confirm('¿Confirmas guardar las calificaciones del @Model.ParcialNombre para @Model.Filas.Count estudiantes?')) {
                e.preventDefault();
            }
        }
    });
});
</script>
}
