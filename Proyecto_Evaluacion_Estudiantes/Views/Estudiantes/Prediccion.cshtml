@model Proyecto_Evaluacion_Estudiantes.Models.PrediccionViewModel
@{
    ViewData["Title"] = "Predicción IA (Riesgo) — EduPath AI";
    ViewData["ActiveMenu"] = "Informacion";
}

<div class="page-wrapper">
    <div class="content">

        <div class="page-header">
            <div class="page-title">
                <h4>
                    <i data-feather="cpu" class="icon-page-header me-2"></i>
                    Predicción IA — Estudiantes en Riesgo
                </h4>
                <h6>EduPath AI — Detección temprana basada en desempeño académico</h6>
            </div>
            <div class="page-btn d-flex gap-2 flex-wrap">
                <a asp-controller="Estudiantes" asp-action="Registro" class="btn-nav-est">
                    <i data-feather="user-plus"></i> Registrar Estudiante
                </a>
                <a asp-controller="Estudiantes" asp-action="Index" class="btn-nav-est">
                    <i data-feather="list"></i> Lista de Estudiantes
                </a>
            </div>
        </div>

        <!-- Cabecera informativa -->
        <div class="alert d-flex align-items-start mb-4 py-3 alert-info-gradient">
            <i data-feather="info" class="info-panel-icon me-3 mt-1 flex-shrink-0"></i>
            <div class="info-panel-text">
                <strong>¿Cómo funciona la predicción?</strong><br>
                EduPath AI analiza el historial de calificaciones de cada estudiante y detecta aquellos con mayor
                probabilidad de reprobar. Se clasifican en dos grupos:
                <strong class="text-danger">Riesgo Alto</strong> (promedio &lt; 60 o marcado por IA) y
                <strong style="color:#fdcb6e;">Zona de Atención</strong> (promedio entre 60–70).
                <br><small class="text-muted">Total analizado: <strong>@Model.TotalAnalizados estudiantes</strong></small>
            </div>
        </div>

        <!-- Riesgo Alto -->
        <div class="card mb-4 card-border-danger">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle-red">
                        <i data-feather="alert-circle" class="icon-18-white"></i>
                    </div>
                    <div>
                        <h6 class="card-section-title">
                            Riesgo Alto
                            <span class="badge ms-2 badge-riesgo-alto">@Model.EstudiantesRiesgo.Count</span>
                        </h6>
                        <small class="text-muted">Promedio &lt; 60 — Requiere intervención inmediata</small>
                    </div>
                </div>

                @if (!Model.EstudiantesRiesgo.Any())
                {
                    <div class="text-center py-3 text-muted">
                        <i data-feather="check-circle" class="icon-check-empty mb-2 d-block mx-auto"></i>
                        Ningún estudiante en riesgo alto. ¡Excelente!
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="thead-light-red">
                                <tr>
                                    <th>Estudiante</th>
                                    <th class="w-col-80">Sección</th>
                                    <th class="w-col-75">P1</th>
                                    <th class="w-col-75">P2</th>
                                    <th class="w-col-75">P3</th>
                                    <th class="w-col-75">P4</th>
                                    <th class="w-col-90">Promedio</th>
                                    <th class="w-col-90">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var est in Model.EstudiantesRiesgo)
                                {
                                    <tr>
                                        <td>
                                            <strong>@est.NombreCompleto</strong>
                                            <br><small class="text-muted">@est.Correo</small>
                                        </td>
                                        <td><small>@(est.Seccion ?? "—")</small></td>
                                        <td>
                                            @if (est.Nota1.HasValue)
                                            { <span class="badge @(est.Nota1 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota1.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota2.HasValue)
                                            { <span class="badge @(est.Nota2 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota2.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota3.HasValue)
                                            { <span class="badge @(est.Nota3 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota3.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota4.HasValue)
                                            { <span class="badge @(est.Nota4 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota4.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Promedio.HasValue)
                                            {
                                                <strong class="promedio-riesgo">@est.Promedio.Value.ToString("F1")</strong>
                                            }
                                            else { <span class="text-muted">Sin datos</span> }
                                        </td>
                                        <td>
                                            <a asp-controller="Estudiantes" asp-action="Editar"
                                               asp-route-id="@est.Id"
                                               class="btn btn-sm btn-action-mini">
                                                <i data-feather="edit-2" class="icon-11"></i> Editar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- Zona de Atención -->
        <div class="card card-border-warning">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="icon-circle-yellow">
                        <i data-feather="alert-triangle" class="icon-18-dark"></i>
                    </div>
                    <div>
                        <h6 class="card-section-title">
                            Zona de Atención
                            <span class="badge ms-2 badge-atencion">@Model.EstudiantesAtencion.Count</span>
                        </h6>
                        <small class="text-muted">Promedio 60–70 — Seguimiento recomendado</small>
                    </div>
                </div>

                @if (!Model.EstudiantesAtencion.Any())
                {
                    <div class="text-center py-3 text-muted">
                        <i data-feather="thumbs-up" class="icon-thumb-empty mb-2 d-block mx-auto"></i>
                        Ningún estudiante en zona límite.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="thead-light-yellow">
                                <tr>
                                    <th>Estudiante</th>
                                    <th class="w-col-80">Sección</th>
                                    <th class="w-col-75">P1</th>
                                    <th class="w-col-75">P2</th>
                                    <th class="w-col-75">P3</th>
                                    <th class="w-col-75">P4</th>
                                    <th class="w-col-90">Promedio</th>
                                    <th class="w-col-90">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var est in Model.EstudiantesAtencion)
                                {
                                    <tr>
                                        <td>
                                            <strong>@est.NombreCompleto</strong>
                                            <br><small class="text-muted">@est.Correo</small>
                                        </td>
                                        <td><small>@(est.Seccion ?? "—")</small></td>
                                        <td>
                                            @if (est.Nota1.HasValue)
                                            { <span class="badge @(est.Nota1 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota1.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota2.HasValue)
                                            { <span class="badge @(est.Nota2 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota2.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota3.HasValue)
                                            { <span class="badge @(est.Nota3 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota3.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Nota4.HasValue)
                                            { <span class="badge @(est.Nota4 >= 60 ? "bg-success" : "bg-danger") badge-nota-sm">@est.Nota4.Value.ToString("F0")</span> }
                                            else { <span class="text-muted text-sin-nota">—</span> }
                                        </td>
                                        <td>
                                            @if (est.Promedio.HasValue)
                                            {
                                                <strong class="promedio-atencion">@est.Promedio.Value.ToString("F1")</strong>
                                            }
                                            else { <span class="text-muted">Sin datos</span> }
                                        </td>
                                        <td>
                                            <a asp-controller="Estudiantes" asp-action="Editar"
                                               asp-route-id="@est.Id"
                                               class="btn btn-sm btn-action-mini">
                                                <i data-feather="edit-2" class="icon-11"></i> Editar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        if (window.feather) feather.replace();
    });
</script>
}
